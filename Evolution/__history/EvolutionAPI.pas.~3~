function TEvolutionAPI.SendMessage(const ANumber: string; const AMessage: string): TEvolutionResponse;
var
  JSONData: TJSONObject;
  OptionsObj: TJSONObject;
  TextMessage: TJSONObject;
  JSONString: string;
begin
  JSONData := TJSONObject.Create;
  try
    // Crear objeto options (requerido por la API)
    OptionsObj := TJSONObject.Create;
    OptionsObj.AddPair('delay', TJSONNumber.Create(0));
    OptionsObj.AddPair('presence', 'composing');
    OptionsObj.AddPair('linkPreview', TJSONBool.Create(true));
    
    // Crear objeto textMessage
    TextMessage := TJSONObject.Create;
    TextMessage.AddPair('text', AMessage);
    
    // Crear JSON principal - Estructura corregida según error del servidor
    JSONData.AddPair('number', ANumber);
    JSONData.AddPair('text', AMessage);  // Agregar text directo según el error "instance requires property text"
    JSONData.AddPair('options', OptionsObj);
    JSONData.AddPair('textMessage', TextMessage);
    
    JSONString := JSONData.ToString;
    
    // JSON generado correctamente
    
    Result := SendRequest('/message/sendText', JSONString);
  finally
    JSONData.Free;
  end;
end;

// Nueva función SendMessageV2 con estructura JSON completa según especificación
function TEvolutionAPI.SendMessageV2(const ANumber: string; const AMessage: string; const AOptions: TTextMessageOptions): TEvolutionResponse;
var
  JSONData: TJSONObject;
  OptionsObj: TJSONObject;
  TextMessage: TJSONObject;
  QuotedObj: TJSONObject;
  QuotedKeyObj: TJSONObject;
  QuotedMessageObj: TJSONObject;
  MentionsObj: TJSONObject;
  MentionedArray: TJSONArray;
  i: Integer;
begin
  JSONData := TJSONObject.Create;
  try
    // Crear objeto options
    OptionsObj := TJSONObject.Create;
    if AOptions.Delay > 0 then
      OptionsObj.AddPair('delay', TJSONNumber.Create(AOptions.Delay));
    if AOptions.Presence <> '' then
      OptionsObj.AddPair('presence', AOptions.Presence);
    OptionsObj.AddPair('linkPreview', TJSONBool.Create(AOptions.LinkPreview));
    
    // Agregar quoted si se especifica
    if AOptions.UseQuoted then
    begin
      QuotedObj := TJSONObject.Create;
      
      QuotedKeyObj := TJSONObject.Create;
      QuotedKeyObj.AddPair('remoteJid', AOptions.Quoted.Key.RemoteJid);
      QuotedKeyObj.AddPair('fromMe', TJSONBool.Create(AOptions.Quoted.Key.FromMe));
      QuotedKeyObj.AddPair('id', AOptions.Quoted.Key.Id);
      QuotedKeyObj.AddPair('participant', AOptions.Quoted.Key.Participant);
      
      QuotedMessageObj := TJSONObject.Create;
      QuotedMessageObj.AddPair('conversation', AOptions.Quoted.Message.Conversation);
      
      QuotedObj.AddPair('key', QuotedKeyObj);
      QuotedObj.AddPair('message', QuotedMessageObj);
      
      OptionsObj.AddPair('quoted', QuotedObj);
    end;
    
    // Agregar mentions si se especifica
    if AOptions.UseMentions then
    begin
      MentionsObj := TJSONObject.Create;
      MentionsObj.AddPair('everyOne', TJSONBool.Create(AOptions.Mentions.EveryOne));
      
      if Length(AOptions.Mentions.Mentioned) > 0 then
      begin
        MentionedArray := TJSONArray.Create;
        for i := 0 to High(AOptions.Mentions.Mentioned) do
          MentionedArray.AddElement(TJSONString.Create(AOptions.Mentions.Mentioned[i]));
        MentionsObj.AddPair('mentioned', MentionedArray);
      end;
      
      OptionsObj.AddPair('mentions', MentionsObj);
    end;
    
    // Crear objeto textMessage
    TextMessage := TJSONObject.Create;
    TextMessage.AddPair('text', AMessage);
    
    // Crear JSON principal
    JSONData.AddPair('number', ANumber);
    JSONData.AddPair('options', OptionsObj);
    JSONData.AddPair('textMessage', TextMessage);
    
    Result := SendRequest('/message/sendText', JSONData.ToString);
  finally
    JSONData.Free;
  end;
end;

// Sobrecarga simplificada de SendMessageV2
function TEvolutionAPI.SendMessageV2(const ANumber: string; const AMessage: string; ADelay: Integer; const APresence: string; ALinkPreview: Boolean): TEvolutionResponse;
var
  Options: TTextMessageOptions;
begin
  // Preparar opciones básicas
  Options.Delay := ADelay;
  Options.Presence := APresence;
  Options.LinkPreview := ALinkPreview;
  Options.UseQuoted := False;
  Options.UseMentions := False;
  
  Result := SendMessageV2(ANumber, AMessage, Options);
end;

// Función para enviar mensajes con menciones
function TEvolutionAPI.SendMessageWithMentions(const ANumber: string; const AMessage: string; const AMentioned: TArray<string>; AMentionEveryone: Boolean): TEvolutionResponse;
var
  Options: TTextMessageOptions;
begin
  // Preparar opciones con menciones
  Options.Delay := 0;
  Options.Presence := 'composing';
  Options.LinkPreview := true;
  Options.UseQuoted := False;
  Options.UseMentions := True;
  
  Options.Mentions.EveryOne := AMentionEveryone;
