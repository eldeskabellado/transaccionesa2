function TEvolutionAPI.CreateInstanceAndGetQR(const AInstanceName, APhoneNumber, AWebhookUrl: string): TEvolutionResponse;
var
  JSONPayload: TJSONObject;
begin
  // Construimos el JSON para la creación de la instancia
  JSONPayload := TJSONObject.Create;
  try
    JSONPayload.AddPair('instanceName', AInstanceName);
    JSONPayload.AddPair('qrcode', TJSONBool.Create(True)); // ¡Importante! Indica que genere el QR
    JSONPayload.AddPair('number', APhoneNumber);
    if AWebhookUrl <> '' then
      JSONPayload.AddPair('webhook', AWebhookUrl);
    // Puedes añadir más parámetros si lo necesitas (token, etc.)

    // Llamamos a SendRequest con el endpoint correcto y el payload
    Result := SendRequest('/instance/create', JSONPayload.ToString);
  finally
    JSONPayload.Free;
  end;
end;

function TEvolutionAPI.GeneratePDF(const AContent: string; const AFileName: string): string;
var
  PDFContent: TStringList;
  PDFPath: string;
begin
  // Simulación de generación de PDF - En un caso real usarías una librería como QuickPDF o FastReport
  PDFPath := ExtractFilePath(Application.ExeName) + 'PDFs\';
  if not TDirectory.Exists(PDFPath) then
    TDirectory.CreateDirectory(PDFPath);
    
  PDFPath := PDFPath + AFileName + '_' + System.SysUtils.FormatDateTime('yyyymmdd_hhnnss', Now) + '.pdf';
  
  PDFContent := TStringList.Create;
  try
    PDFContent.Add('=== REPORTE MÉDICO ===');
    PDFContent.Add('Fecha de generación: ' + DateTimeToStr(Now));
    PDFContent.Add('');
    PDFContent.Add(AContent);
    PDFContent.Add('');
    PDFContent.Add('=== FIN DEL REPORTE ===');
    
    // En un caso real, aquí generarías el PDF usando una librería especializada
    PDFContent.SaveToFile(ChangeFileExt(PDFPath, '.txt')); // Guardamos como texto por simplicidad
    
    Result := ChangeFileExt(PDFPath, '.txt');
  finally
    PDFContent.Free;
  end;
end;

function TEvolutionAPI.FileToBase64(const AFilePath: string): string;
var
  FileStream: TFileStream;
  Base64Stream: TStringStream;
  FileSize: Int64;
const
  MAX_FILE_SIZE = 2 * 1024 * 1024;
begin
  Result := '';
  if not TFile.Exists(AFilePath) then
    raise Exception.Create('Archivo no encontrado: ' + AFilePath);

  FileStream := TFileStream.Create(AFilePath, fmOpenRead);
  try
    FileSize := FileStream.Size;
    if FileSize > MAX_FILE_SIZE then
      raise Exception.Create(Format('Archivo demasiado grande: %d bytes. Máximo permitido: %d bytes', [FileSize, MAX_FILE_SIZE]));

    if FileSize = 0 then
      raise Exception.Create('El archivo está vacío');
  finally
    FileStream.Free;
  end;

  ShowMessage(Format('Procesando archivo: %s (%.2f KB)', [ExtractFileName(AFilePath), FileSize / 1024]));

  FileStream := TFileStream.Create(AFilePath, fmOpenRead);
  try
    Base64Stream := TStringStream.Create;
    try
      TNetEncoding.Base64.Encode(FileStream, Base64Stream);
      Result := Base64Stream.DataString;

      // *** AGREGAR ESTAS LÍNEAS ***
      Result := StringReplace(Result, #13#10, '', [rfReplaceAll]);
      Result := StringReplace(Result, #13, '', [rfReplaceAll]);
      Result := StringReplace(Result, #10, '', [rfReplaceAll]);
      Result := StringReplace(Result, ' ', '', [rfReplaceAll]);
      // *** FIN DE LÍNEAS A AGREGAR ***

      ShowMessage(Format('Base64 generado y limpiado: %d caracteres', [Length(Result)]));
    finally
      Base64Stream.Free;
    end;
  finally
    FileStream.Free;
  end;
end;

function TEvolutionAPI.GetMediaTypeString(AMediaType: TMediaType): string;
begin
  case AMediaType of
    mtImage: Result := 'image';
    mtDocument: Result := 'document';
    mtAudio: Result := 'audio';
    mtVideo: Result := 'video';
  else
    Result := 'document';
  end;
end;

function TEvolutionAPI.DetectMediaTypeFromFile(const AFilePath: string): TMediaType;
var
  FileExt: string;
begin
  FileExt := LowerCase(ExtractFileExt(AFilePath));
  
  // Tipos de imagen
  if (FileExt = '.jpg') or (FileExt = '.jpeg') or (FileExt = '.png') or 
     (FileExt = '.gif') or (FileExt = '.bmp') or (FileExt = '.webp') then
    Result := mtImage
  // Tipos de audio
  else if (FileExt = '.mp3') or (FileExt = '.wav') or (FileExt = '.ogg') or 
          (FileExt = '.m4a') or (FileExt = '.aac') then
    Result := mtAudio
  // Tipos de video
  else if (FileExt = '.mp4') or (FileExt = '.avi') or (FileExt = '.mov') or 
          (FileExt = '.wmv') or (FileExt = '.mkv') then
    Result := mtVideo
  // Todo lo demás como documento
  else
    Result := mtDocument;
end;

