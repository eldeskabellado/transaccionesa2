constructor TEvolutionAPI.Create(const ABaseURL: string; const AInstanceID: string; const AAPIKey: string; ATimeout: Integer);
begin
  inherited Create;
  FBaseURL := ABaseURL;
  FInstanceID := AInstanceID;
  FAPIKey := AAPIKey;
  FTimeout := ATimeout;
  FHttpClient := THTTPClient.Create;
  FHttpClient.ConnectionTimeout := FTimeout;
  FHttpClient.ResponseTimeout := FTimeout;
end;

destructor TEvolutionAPI.Destroy;
begin
  FHttpClient.Free;
  inherited Destroy;
end;

function TEvolutionAPI.IsInstanceConnected: Boolean;
var
  Response: TEvolutionResponse;
  JSONObj: TJSONObject;
  InstanceObj: TJSONObject;
  State: string;
begin
  Result := False;

  try
    Response := GetInstanceStatus;

    if Response.Success then
    begin
      JSONObj := TJSONObject.ParseJSONValue(Response.Data) as TJSONObject;
      if Assigned(JSONObj) then
      begin
        try
          InstanceObj := JSONObj.GetValue<TJSONObject>('instance');
          if Assigned(InstanceObj) then
          begin
            State := InstanceObj.GetValue<string>('state');
            Result := (LowerCase(State) = 'open');
          end;
        finally
          JSONObj.Free;
        end;
      end;
    end;
  except
    Result := False;
  end;
end;



function TEvolutionAPI.SendRequest(const AEndpoint: string; const AData: string): TEvolutionResponse;
var
  Response: IHTTPResponse;
  JSONRequest: string;
  JSONResponse: TJSONObject;
  URL: string;
begin
  Result.Success := False;
  Result.Message := '';
  Result.Data := '';
  Result.ErrorCode := 0;

  try
    // --- MODIFICACIÓN CLAVE AQUÍ ---
    // El endpoint de creación es diferente, no lleva el InstanceID
    if (Pos('/instance/create', AEndpoint) > 0) then
    begin
      URL := FBaseURL + AEndpoint;
    end
    // Para los demás endpoints que usan la instancia en la URL
    else if (Pos('/connect', AEndpoint) > 0) or (Pos('/connectionState', AEndpoint) > 0) then
      URL := FBaseURL + '/instance' + AEndpoint + '/' + FInstanceID
    else if (Pos('/message/sendMedia', AEndpoint) > 0) or (Pos('/message/sendText', AEndpoint) > 0) then
      URL := FBaseURL + AEndpoint + '/' + FInstanceID
    else
      URL := FBaseURL + '/instance' + AEndpoint + '/' + FInstanceID;

    FHttpClient.CustomHeaders['Content-Type'] := 'application/json';
    FHttpClient.CustomHeaders['apikey'] := FAPIKey;

    {$IFDEF DEBUG}
    ShowMessage('URL generada: ' + URL + #13#10 + 'Datos: ' + AData);
    {$ENDIF}

    // La creación de instancia y envío de mensajes son POST
    if (Pos('/instance/create', AEndpoint) > 0) or (Pos('/message/', AEndpoint) > 0) then
    begin
      JSONRequest := AData;
      Response := FHttpClient.Post(URL, TStringStream.Create(JSONRequest, TEncoding.UTF8));
    end
    // Para endpoints que requieren GET (connect, connectionState)
    else
    begin
      Response := FHttpClient.Get(URL);
    end;

    if (Response.StatusCode = 200) or (Response.StatusCode = 201) then
    begin
      Result.Success := True;
      Result.Message := 'Success';
      Result.Data := Response.ContentAsString(TEncoding.UTF8); // Usar UTF8 es buena práctica

      try
        JSONResponse := TJSONObject.ParseJSONValue(Response.ContentAsString(TEncoding.UTF8)) as TJSONObject;
        if Assigned(JSONResponse) then
        begin
          if JSONResponse.TryGetValue<string>('message', Result.Message) then
            // Usar el mensaje de la respuesta si existe
          else if JSONResponse.TryGetValue<string>('error', Result.Message) then
          begin
            Result.Success := False;
          end;
          Result.ErrorCode := JSONResponse.GetValue<Integer>('errorCode', 0);
          JSONResponse.Free;
        end;
      except
        // Si no se puede parsear como JSON, no es problema
      end;
    end
    else
    begin
      Result.Success := False;
      Result.Message := 'Error HTTP: ' + IntToStr(Response.StatusCode) + ' - ' + Response.StatusText;
      Result.Data := Response.ContentAsString(TEncoding.UTF8);
      Result.ErrorCode := Response.StatusCode;
    end;

  except
    on E: Exception do
    begin
      Result.Success := False;
      Result.Message := 'Error de conexión: ' + E.Message;
      Result.ErrorCode := -1;
    end;
  end;
end;
