  MediaMessage.Base64Data := '';
  
  // Preparar opciones
  Options.Delay := ADelay;
  Options.Presence := 'composing';
  
  Result := SendMediaMessageV2(ANumber, MediaMessage, Options);
end;

// Función simple para envío de medios con JSON mínimo
// Reemplaza la función SendMediaSimple con esta versión CORRECTA:

function TEvolutionAPI.SendMediaSimple(const ANumber: string; const AFilePath: string; const ACaption: string): TEvolutionResponse;
var
  JSONData: TJSONObject;
  Base64Data: string;
  MediaType: string;
  MimeType: string;
  FileExt: string;
  CleanNumber: string;
begin
  JSONData := TJSONObject.Create;
  try
    // Limpiar número (quitar @s.whatsapp.net si existe)
    CleanNumber := ANumber;
    if Pos('@s.whatsapp.net', CleanNumber) > 0 then
      CleanNumber := StringReplace(CleanNumber, '@s.whatsapp.net', '', [rfReplaceAll]);

    // Detectar tipo de media y mimetype
    FileExt := LowerCase(ExtractFileExt(AFilePath));
    if (FileExt = '.jpg') or (FileExt = '.jpeg') then
    begin
      MediaType := 'image';
      MimeType := 'image/jpeg';
    end
    else if FileExt = '.png' then
    begin
      MediaType := 'image';
      MimeType := 'image/png';
    end
    else if FileExt = '.pdf' then
    begin
      MediaType := 'document';
      MimeType := 'application/pdf';
    end
    else if (FileExt = '.mp4') or (FileExt = '.avi') or (FileExt = '.mov') then
    begin
      MediaType := 'video';
      MimeType := 'video/mp4';
    end
    else if (FileExt = '.mp3') or (FileExt = '.ogg') or (FileExt = '.wav') then
    begin
      MediaType := 'audio';
      MimeType := 'audio/mpeg';
    end
    else
    begin
      MediaType := 'document';
      MimeType := 'application/octet-stream';
    end;

    // Convertir archivo a Base64
    ShowMessage('Iniciando conversión a Base64...');
    Base64Data := FileToBase64(AFilePath);
    ShowMessage('Conversión completada. Tamaño: ' + IntToStr(Length(Base64Data)) + ' caracteres');

    // ESTRUCTURA V2: Todos los campos en el nivel superior, sin objetos anidados
    JSONData.AddPair('number', CleanNumber);
    JSONData.AddPair('mediatype', MediaType);
    JSONData.AddPair('mimetype', MimeType);
    JSONData.AddPair('media', Base64Data);  // Solo Base64 puro
    JSONData.AddPair('fileName', ExtractFileName(AFilePath));

    if ACaption <> '' then
      JSONData.AddPair('caption', ACaption);

    // Opcionales
    JSONData.AddPair('delay', TJSONNumber.Create(1200));

    // Debug
    ShowMessage('JSON generado (estructura V2):' + #13#10 +
                StringReplace(JSONData.ToString, Base64Data,
                             '...BASE64_TRUNCADO (' + IntToStr(Length(Base64Data)) + ' chars)...',
                             [rfReplaceAll]));

    Result := SendRequest('/message/sendMedia', JSONData.ToString);
  finally
    JSONData.Free;
  end;
end;

// Actualizar GenerateMediaJSON para V2
function TEvolutionAPI.GenerateMediaJSON(const ANumber: string; const AFilePath: string; const ACaption: string): string;
var
  JSONData: TJSONObject;
  Base64Data: string;
  MediaType: string;
  MimeType: string;
  FileExt: string;
  CleanNumber: string;
begin
  JSONData := TJSONObject.Create;
  try
    // Limpiar número
    CleanNumber := ANumber;
    if Pos('@s.whatsapp.net', CleanNumber) > 0 then
      CleanNumber := StringReplace(CleanNumber, '@s.whatsapp.net', '', [rfReplaceAll]);

    // Detectar tipo de media
    FileExt := LowerCase(ExtractFileExt(AFilePath));
    if (FileExt = '.jpg') or (FileExt = '.jpeg') then
    begin
      MediaType := 'image';
      MimeType := 'image/jpeg';
    end
    else if FileExt = '.png' then
    begin
      MediaType := 'image';
      MimeType := 'image/png';
    end
    else if FileExt = '.pdf' then
    begin
      MediaType := 'document';
      MimeType := 'application/pdf';
    end
    else
    begin
      MediaType := 'document';
      MimeType := 'application/octet-stream';
    end;

    // Convertir archivo a Base64 (truncado para visualización)
    Base64Data := Copy(FileToBase64(AFilePath), 1, 100);

    // Estructura V2: plana, sin objetos anidados
    JSONData.AddPair('number', CleanNumber);
    JSONData.AddPair('mediatype', MediaType);
    JSONData.AddPair('mimetype', MimeType);
    JSONData.AddPair('media', Base64Data + '...TRUNCADO');
    JSONData.AddPair('fileName', ExtractFileName(AFilePath));

    if ACaption <> '' then
      JSONData.AddPair('caption', ACaption);

    JSONData.AddPair('delay', TJSONNumber.Create(1200));

    Result := JSONData.ToString;
  finally
    JSONData.Free;
  end;
