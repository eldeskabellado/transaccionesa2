unit UnitVerCompras;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Data.DB, Vcl.Grids, Vcl.DBGrids,
  dbisamtb, Vcl.StdCtrls;

type
  TFormVerCompras = class(TForm)
    sqfacturas: TDBISAMQuery;
    dsqfacturas: TDataSource;
    DBGrid1: TDBGrid;
    Button1: TButton;
    procedure DBGrid1DblClick(Sender: TObject);
    procedure Button1Click(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    codigoProveedor,
    numeroFactura:string;
  end;

var
  FormVerCompras: TFormVerCompras;

implementation

{$R *.dfm}

uses UnitDatos;

procedure TFormVerCompras.Button1Click(Sender: TObject);
begin
  with sqfacturas do
  begin
    close;
     Parambyname('proveedor').AsString:=codigoproveedor;
    Parambyname('Ttipo').AsInteger:=6;
    Open;
  end;
end;

procedure TFormVerCompras.DBGrid1DblClick(Sender: TObject);
begin
numerofactura:=sqfacturas.FieldByName('FTI_RESPONSABLE').AsString;
close;
end;

end.
