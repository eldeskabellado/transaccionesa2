unit UnitAcercade;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants,
  System.Classes, Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs,
  Vcl.StdCtrls, Vcl.ExtCtrls, System.JSON, System.NetEncoding;

type
  // ✅ Estructura EXACTA de la DLL
  TEvolutionResult = record
    Success: Boolean;
    Message: array[0..1023] of Char;
    Data: array[0..8191] of Char;
    ErrorCode: Integer;
  end;

  TformConectar = class(TForm)
    btnMostrarQR: TButton;
    imgQR: TImage;
    lblEstado: TLabel;
    Timer1: TTimer;
    btnEnviarMensaje: TButton;
    edtTelefono: TEdit;
    memoMensaje: TMemo;
    procedure btnMostrarQRClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure Timer1Timer(Sender: TObject);
    procedure btnEnviarMensajeClick(Sender: TObject);
    procedure btnTestConexionClick(Sender: TObject);
  private
    FConectado: Boolean;
    procedure ActualizarEstado;
  public
    { Public declarations }
  end;

var
  formConectar: TformConectar;

// ✅ FUNCIONES EXPORTADAS DE LA DLL (nombres exactos)
function EVO_Initialize(IniFilePath: PChar): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
procedure EVO_Finalize; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SetConfig(BaseURL, InstanceID, APIKey: PChar): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_GetConfig(Buffer: PChar; BufferSize: Integer): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_TestConnection(out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_GetQRCode(out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_GetInstanceStatus(out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_IsConnected: Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SendMessage(PhoneNumber, Message: PChar; out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SendMessageEx(PhoneNumber, Message: PChar; Delay: Integer; Presence: PChar; LinkPreview: Boolean; out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SendImage(PhoneNumber, ImagePath, Caption: PChar; out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SendPDF(PhoneNumber, PDFPath, Caption: PChar; out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_SendMedia(PhoneNumber, FilePath, Caption: PChar; out AResult: TEvolutionResult): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_GetLastError(Buffer: PChar; BufferSize: Integer): Boolean; stdcall; external 'EvolutionAPI_DLL.dll';
function EVO_GetVersion: PChar; stdcall; external 'EvolutionAPI_DLL.dll';

implementation

{$R *.dfm}

procedure TformConectar.FormCreate(Sender: TObject);
var
  IniPath: string;
begin
  FConectado := False;
  imgQR.Visible := False;

  // Opción 1: Usar archivo .ini
  IniPath := ExtractFilePath(Application.ExeName) + 'config.ini';

  if EVO_Initialize(PChar(IniPath)) then
  begin
    lblEstado.Caption := '✓ DLL inicializada desde .ini';
    lblEstado.Font.Color := clGreen;
    Timer1.Enabled := True;
  end
  else
  begin
    // Opción 2: Configurar manualmente si no existe el .ini
    if EVO_SetConfig(
      PChar('http://localhost:8080'),  // BaseURL
      PChar('MI_INSTANCIA'),            // InstanceID
      PChar('TU_API_KEY')               // APIKey
    ) then
    begin
      lblEstado.Caption := '✓ DLL configurada manualmente';
      lblEstado.Font.Color := clGreen;
      Timer1.Enabled := True;
    end
    else
    begin
      lblEstado.Caption := '✗ Error al inicializar DLL';
      lblEstado.Font.Color := clRed;
    end;
  end;
end;

procedure TformConectar.FormDestroy(Sender: TObject);
begin
  Timer1.Enabled := False;
  EVO_Finalize;
end;

procedure TformConectar.Timer1Timer(Sender: TObject);
begin
  ActualizarEstado;
end;

procedure TformConectar.ActualizarEstado;
var
  Res: TEvolutionResult;
  JSON: TJSONObject;
  Estado: string;
  DataStr: string;
begin
  if not EVO_GetInstanceStatus(Res) then Exit;

  if not Res.Success then Exit;

  try
    // Convertir el array de Char a string
    DataStr := string(Res.Data);

    JSON := TJSONObject.ParseJSONValue(DataStr) as TJSONObject;
    if Assigned(JSON) then
    try
      // Verificar si existe el campo 'state'
      if JSON.TryGetValue<string>('state', Estado) then
      begin
        if Estado = 'open' then
        begin
          lblEstado.Caption := '✓ WhatsApp Conectado';
          lblEstado.Font.Color := clGreen;
          imgQR.Visible := False;
          btnMostrarQR.Enabled := False;
          btnEnviarMensaje.Enabled := True;
          FConectado := True;
        end
        else if Estado = 'close' then
        begin
          lblEstado.Caption := '✗ Desconectado - Genera QR';
          lblEstado.Font.Color := clRed;
          btnMostrarQR.Enabled := True;
          btnEnviarMensaje.Enabled := False;
          FConectado := False;
        end
        else
        begin
          lblEstado.Caption := 'Estado: ' + Estado;
          lblEstado.Font.Color := clBlue;
        end;
      end
      else
      begin
        // Si no hay campo 'state', verificar con EVO_IsConnected
        if EVO_IsConnected then
        begin
          lblEstado.Caption := '✓ Conectado';
          lblEstado.Font.Color := clGreen;
          FConectado := True;
        end
        else
        begin
          lblEstado.Caption := '✗ Desconectado';
          lblEstado.Font.Color := clRed;
          FConectado := False;
        end;
      end;
    finally
      JSON.Free;
    end;
  except
    on E: Exception do
    begin
      // Usar función alternativa si falla el parseo JSON
      if EVO_IsConnected then
      begin
        lblEstado.Caption := '✓ Conectado';
        lblEstado.Font.Color := clGreen;
        FConectado := True;
      end
      else
      begin
        lblEstado.Caption := '? Estado desconocido';
        lblEstado.Font.Color := clGray;
      end;
    end;
  end;
end;

procedure TformConectar.btnMostrarQRClick(Sender: TObject);
var
  Res: TEvolutionResult;
  JSON: TJSONObject;
  Base64QR: string;
  Stream: TMemoryStream;
  Bytes: TBytes;
  DataStr: string;
begin
  lblEstado.Caption := 'Generando código QR...';
  lblEstado.Font.Color := clBlue;
  Application.ProcessMessages;

  if not EVO_GetQRCode(Res) then
  begin
    ShowMessage('Error al obtener QR: ' + string(Res.Message));
    lblEstado.Caption := '✗ Error al generar QR';
    lblEstado.Font.Color := clRed;
    Exit;
  end;

  if not Res.Success then
  begin
    ShowMessage('Error: ' + string(Res.Message));
    Exit;
  end;

  try
    DataStr := string(Res.Data);
    JSON := TJSONObject.ParseJSONValue(DataStr) as TJSONObject;

    if not Assigned(JSON) then
    begin
      ShowMessage('Error: respuesta JSON inválida');
      Exit;
    end;

    try
      if JSON.TryGetValue<string>('qrcode', Base64QR) then
      begin
        // Limpiar prefijo data:image si existe
        if Pos('base64,', Base64QR) > 0 then
          Base64QR := Copy(Base64QR, Pos('base64,', Base64QR) + 7, Length(Base64QR));

        Bytes := TNetEncoding.Base64.DecodeStringToBytes(Base64QR);

        Stream := TMemoryStream.Create;
        try
          Stream.WriteBuffer(Bytes[0], Length(Bytes));
          Stream.Position := 0;
          imgQR.Picture.LoadFromStream(Stream);
          imgQR.Stretch := True;
          imgQR.Proportional := True;
          imgQR.Visible := True;
        finally
          Stream.Free;
        end;

        lblEstado.Caption := '📱 Escanea el QR con WhatsApp';
        lblEstado.Font.Color := clBlue;
        ShowMessage('Escanea el código QR con WhatsApp en tu celular');
      end
      else
      begin
        ShowMessage('No se encontró el código QR en la respuesta');
      end;
    finally
      JSON.Free;
    end;
  except
    on E: Exception do
    begin
      ShowMessage('Error procesando QR: ' + E.Message);
      lblEstado.Caption := '✗ Error al procesar QR';
      lblEstado.Font.Color := clRed;
    end;
  end;
end;

procedure TformConectar.btnEnviarMensajeClick(Sender: TObject);
var
  Res: TEvolutionResult;
  Telefono, Mensaje: string;
begin
  if not FConectado then
  begin
    ShowMessage('Debes conectar WhatsApp primero');
    Exit;
  end;

  Telefono := Trim(edtTelefono.Text);
  Mensaje := Trim(memoMensaje.Text);

  if (Telefono = '') or (Mensaje = '') then
  begin
    ShowMessage('Ingresa teléfono y mensaje');
    Exit;
  end;

  // Limpiar el número (solo dígitos)
  Telefono := StringReplace(Telefono, '-', '', [rfReplaceAll]);
  Telefono := StringReplace(Telefono, ' ', '', [rfReplaceAll]);
  Telefono := StringReplace(Telefono, '(', '', [rfReplaceAll]);
  Telefono := StringReplace(Telefono, ')', '', [rfReplaceAll]);

  // Formato internacional (ejemplo Argentina: 5491112345678)
  if not Telefono.StartsWith('549') then
    Telefono := '549' + Telefono;

  if EVO_SendMessage(
    PChar(Telefono),
    PChar(Mensaje),
    Res
  ) then
  begin
    if Res.Success then
    begin
      ShowMessage('✓ Mensaje enviado correctamente');
      memoMensaje.Clear;
    end
    else
    begin
      ShowMessage('Error al enviar: ' + string(Res.Message));
    end;
  end
  else
  begin
    ShowMessage('Error en la función de envío: ' + string(Res.Message));
  end;
end;

procedure TformConectar.btnTestConexionClick(Sender: TObject);
var
  Res: TEvolutionResult;
  Buffer: array[0..1023] of Char;
begin
  // Test de conexión
  if EVO_TestConnection(Res) then
  begin
    if Res.Success then
      ShowMessage('✓ Conexión exitosa: ' + string(Res.Message))
    else
      ShowMessage('✗ Error: ' + string(Res.Message));
  end
  else
  begin
    ShowMessage('✗ Fallo al probar conexión');
  end;

  // Mostrar configuración actual
  if EVO_GetConfig(@Buffer, Length(Buffer)) then
  begin
    ShowMessage('Configuración actual: ' + string(Buffer));
  end;

  // Mostrar versión
  ShowMessage('Versión DLL: ' + string(EVO_GetVersion));
end;

end.
