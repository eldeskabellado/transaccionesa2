  cdsDetalle.CreateDataSet;
end;

procedure TformPedido.ProcesarArchivoPedido(const NombreArchivo: string);
var
  Archivo: TextFile;
  Linea: string;
  Campos: TStringList;
  CodigoCliente: string;
  PrimeraLinea: Boolean;
  PrecioStr: string;
  CantidadStr: string;
  FormatSettings: TFormatSettings;
begin
  Campos := TStringList.Create;
  try
    Campos.Delimiter := '|';
    Campos.StrictDelimiter := True;

    // Configurar formato para números decimales
    FormatSettings := TFormatSettings.Create;
    FormatSettings.DecimalSeparator := '.';
    FormatSettings.ThousandSeparator := ',';

    // Limpiar el dataset
    cdsDetalle.EmptyDataSet;

    AssignFile(Archivo, NombreArchivo);
    Reset(Archivo);
    PrimeraLinea := True;

    while not Eof(Archivo) do
    begin
      ReadLn(Archivo, Linea);

      if Trim(Linea) <> '' then
      begin
        Campos.DelimitedText := Linea;

        // Debug: mostrar cuántos campos se encontraron
        if PrimeraLinea then
          ShowMessage('Campos encontrados: ' + IntToStr(Campos.Count) + #13#10 +
                     'Precio (campo 3): ' + Campos[3] + #13#10 +
                     'Cantidad (campo 2): ' + Campos[2]);

        if Campos.Count >= 18 then
        begin
          // En la primera línea obtenemos el código del cliente
          if PrimeraLinea then
          begin
            Self.CodigoCliente := Campos[5]; // Posición 5 = CODCLI - Guardar en variable de clase
            CargarDatosCliente(Self.CodigoCliente);
            Pedido := Campos[6]; // ID del pedido
            lblPedido.Caption := Pedido;
            PrimeraLinea := False;
          end;

          // Preparar strings para conversión
          CantidadStr := StringReplace(Campos[2], ',', '.', [rfReplaceAll]);
          PrecioStr := StringReplace(Campos[3], ',', '.', [rfReplaceAll]);

          // Consultar datos de impuestos del artículo
          var TieneImpuesto: Boolean;
          var PorcentajeIVA: Double;
          var PrecioOriginal: Double;
          var PrecioSinIVA: Double;
          var MontoIVA: Double;
          var PrecioConIVA: Double;

          ConsultarDatosImpuestoArticulo(Campos[0], TieneImpuesto, PorcentajeIVA);

          PrecioOriginal := StrToFloatDef(PrecioStr, 0, FormatSettings);

          if TieneImpuesto and (PorcentajeIVA > 0) then
          begin
            // El precio viene con IVA incluido, hay que separarlo
            PrecioSinIVA := PrecioOriginal / (1 + (PorcentajeIVA / 100));
            MontoIVA := PrecioOriginal - PrecioSinIVA;
            PrecioConIVA := PrecioOriginal;
          end
          else
          begin
            // No tiene impuesto
            PrecioSinIVA := PrecioOriginal;
            MontoIVA := 0;
            PrecioConIVA := PrecioOriginal;
          end;

          // Insertar detalle en el dataset
          cdsDetalle.Append;
          cdsDetalle.FieldByName('CODPROD').AsString := Campos[0];
          cdsDetalle.FieldByName('DESPROD').AsString := Campos[1];
          cdsDetalle.FieldByName('CANTIDAD').AsFloat := StrToFloatDef(CantidadStr, 0, FormatSettings);
          cdsDetalle.FieldByName('PRECIO').AsFloat := PrecioOriginal; // Precio original del archivo
          cdsDetalle.FieldByName('SEDE').AsString := Campos[4];
          cdsDetalle.FieldByName('CODCLI').AsString := Campos[5];
          cdsDetalle.FieldByName('ID').AsInteger := StrToIntDef(Campos[6], 0);
          cdsDetalle.FieldByName('DCT').AsFloat := StrToFloatDef(StringReplace(Campos[7], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DCREDITO').AsInteger := StrToIntDef(Campos[8], 0);
          cdsDetalle.FieldByName('ORIGEN').AsString := Campos[9];
          cdsDetalle.FieldByName('TIPO_PEDIDO').AsString := Campos[10];
          cdsDetalle.FieldByName('DA').AsFloat := StrToFloatDef(StringReplace(Campos[11], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DA2').AsFloat := StrToFloatDef(StringReplace(Campos[12], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DV').AsFloat := StrToFloatDef(StringReplace(Campos[13], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DP').AsFloat := StrToFloatDef(StringReplace(Campos[14], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DN_CT').AsFloat := StrToFloatDef(StringReplace(Campos[15], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DNV_CT').AsFloat := StrToFloatDef(StringReplace(Campos[16], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          cdsDetalle.FieldByName('DA3').AsFloat := StrToFloatDef(StringReplace(Campos[17], ',', '.', [rfReplaceAll]), 0, FormatSettings);
          // Campos de impuestos calculados
          cdsDetalle.FieldByName('TIENE_IMPUESTO').AsBoolean := TieneImpuesto;
          cdsDetalle.FieldByName('PORCENTAJE_IVA').AsFloat := PorcentajeIVA;
          cdsDetalle.FieldByName('PRECIO_SIN_IVA').AsFloat := PrecioSinIVA;
          cdsDetalle.FieldByName('MONTO_IVA').AsFloat := MontoIVA;
          cdsDetalle.FieldByName('PRECIO_CON_IVA').AsFloat := PrecioConIVA;
          // Campos de lote con valores por defecto
          cdsDetalle.FieldByName('LOTE').AsString := '000000';
          cdsDetalle.FieldByName('VENCIMIENTO').AsDateTime := StrToDate('30/12/1899'); // Fecha por defecto
          cdsDetalle.FieldByName('RANDON').AsString := '000000';
          cdsDetalle.Post;
        end;
      end;
    end;

    CloseFile(Archivo);

  finally
    Campos.Free;
  end;
end;

procedure TformPedido.btnProcesarClick(Sender: TObject);
begin
  try
    // Validar que hay un pedido cargado
    if not ValidarPedidoCargado then
    begin
      ShowMessage('Debe cargar un pedido antes de procesarlo.');
      Exit;
    end;

    // Crear la cabecera del pedido
    CrearCabeceraPedido(Pedido, CodigoCliente);

  except
    on E: Exception do
      ShowMessage('Error al procesar el pedido: ' + E.Message);
  end;
end;

function TformPedido.ValidarPedidoCargado: Boolean;
begin
  Result := False;

  // Verificar que hay datos cargados
  if cdsDetalle.RecordCount = 0 then
  begin
    ShowMessage('No hay datos de pedido cargados.');
    Exit;
  end;

  // Verificar que se tiene el número de pedido
  if Trim(Pedido) = '' then
  begin
    ShowMessage('No se ha identificado el número de pedido.');
    Exit;
  end;

  // Verificar que se tiene el código del cliente
  if Trim(CodigoCliente) = '' then
  begin
    ShowMessage('No se ha identificado el código del cliente.');
    Exit;
  end;

  // Verificar que el cliente fue encontrado
  if lblCliente.Caption = 'Cliente no encontrado' then
  begin
    ShowMessage('El cliente no fue encontrado en la base de datos.');
    Exit;
  end;

  Result := True;
end;

procedure TformPedido.CrearCabeceraPedido(const NumeroPedido: string; const CodigoCliente: string);
var
  TotalItems: Integer;
  TotalBruto: Currency;
  TotalNeto: Currency;
  AutoIncrement: Integer;
  LineaDetalle: Integer;
begin
  // Calcular totales del detalle
  TotalItems := cdsDetalle.RecordCount;
  TotalBruto := 0;
  var TotalSinIVA: Currency := 0;
  var TotalIVA: Currency := 0;

  cdsDetalle.First;
  while not cdsDetalle.Eof do
  begin
    var CantidadLinea := cdsDetalle.FieldByName('CANTIDAD').AsFloat;
    var PrecioSinIVALinea := cdsDetalle.FieldByName('PRECIO_SIN_IVA').AsFloat;
    var MontoIVALinea := cdsDetalle.FieldByName('MONTO_IVA').AsFloat;

    TotalSinIVA := TotalSinIVA + (CantidadLinea * PrecioSinIVALinea);
    TotalIVA := TotalIVA + (CantidadLinea * MontoIVALinea);
    cdsDetalle.Next;
  end;

  TotalBruto := TotalSinIVA + TotalIVA; // Total con IVA incluido
  TotalNeto := TotalSinIVA; // Total sin IVA

  // Insertar cabecera del pedido
  sqPedido.Close;
  sqPedido.SQL.Clear;
  sqPedido.SQL.Add('INSERT INTO SOperacionInv (');
  sqPedido.SQL.Add('FTI_DOCUMENTO, FTI_TIPO, FTI_STATUS, FTI_VISIBLE, FTI_FECHAEMISION,');
  sqPedido.SQL.Add('FTI_DEPOSITOSOURCE, FTI_DEPOSITODESTINO, FTI_TOTALITEMS, FTI_TOTALITEMSINICIAL, FTI_MONEDA, FTI_FACTORCAMBIO,');
  sqPedido.SQL.Add('FTI_TOTALCOSTO, FTI_TOTALCOSTOREAL, FTI_TOTALBRUTO, FTI_TOTALNETO, FTI_BASEIMPONIBLE, FTI_TOTALPRECIO, FTI_CLASIFICACION,');
  sqPedido.SQL.Add('FTI_DESCRIPCLASIFY, FTI_RIFCLIENTE, FTI_PROPOSITO, FTI_RESPONSABLE, FTI_USER, FTI_AUTORIZADOPOR,');
  sqPedido.SQL.Add('FTI_HORA, FTI_TIPOPRECIO, FTI_EXCENTO, FTI_PERSONACONTACTO, FTI_TELEFONOCONTACTO,');
  sqPedido.SQL.Add('FTI_DIRECCIONDESPACHO, FTI_DIASVENCIMIENTO, FTI_FECHAVENCIDO, FTI_TIENELOTES, FTI_UPDATEITEMS,');
  sqPedido.SQL.Add('FTI_SALDOOPERACION, FTI_MONEDAPAGO, FTI_MACHINENAME, FTI_FACTORREFERENCIA, FTI_COSTODEVENTA,');
  sqPedido.SQL.Add('FTI_VENDEDORASIGNADO, FTI_ZONAVENTA, FTI_PENDINGFORPRINT, FTI_MULTIPLEVENDEDOR, FTI_MULTIPLEDEPOSITO,');
  sqPedido.SQL.Add('FTI_TIMESAVED, FTI_DESCUENTO1PORCENT, FTI_DESCUENTO1MONTO, FTI_DESCUENTO1ORIGEN,');
  sqPedido.SQL.Add('FTI_DESCUENTO2PORCENT, FTI_DESCUENTO2MONTO, FTI_DESCUENTO2ORIGEN, FTI_DESCUENTOPARCIAL,');
  sqPedido.SQL.Add('FTI_FLETEPORCENT, FTI_FLETEMONEDA, FTI_FLETEORIGEN, FTI_BASEIMPONIBLE2,');
  sqPedido.SQL.Add('FTI_IMPUESTO1PORCENT, FTI_IMPUESTO1MONTO, FTI_IMPUESTO2PORCENT, FTI_IMPUESTO2MONTO, FTI_DESCUENTOCUADRE');
  sqPedido.SQL.Add(') VALUES (');
  sqPedido.SQL.Add(':documento, :tipo, :status, :visible, :fechaemision,');
  sqPedido.SQL.Add(':depositosource, :depositodestino, :totalitems, :totalitemsinicial, :moneda, :factorcambio,');
  sqPedido.SQL.Add(':totalcosto, :totalcostoreal, :totalbruto, :totalneto, :baseimponible, :totalprecio, :clasificacion,');
  sqPedido.SQL.Add(':descripclasify, :rifcliente, :proposito, :responsable, :user, :autorizadopor,');
  sqPedido.SQL.Add(':hora, :tipoprecio, :excento, :personacontacto, :telefonocontacto,');
  sqPedido.SQL.Add(':direcciondespacho, :diasvencimiento, :fechavencido, :tienelotes, :updateitems,');
  sqPedido.SQL.Add(':saldooperacion, :monedapago, :machinename, :factorreferencia, :costodeventa,');
  sqPedido.SQL.Add(':vendedorasignado, :zonaventa, :pendingforprint, :multiplevendedor, :multipledeposito,');
  sqPedido.SQL.Add(':timesaved, :descuento1porcent, :descuento1monto, :descuento1origen,');
  sqPedido.SQL.Add(':descuento2porcent, :descuento2monto, :descuento2origen, :descuentoparcial,');
  sqPedido.SQL.Add(':fleteporcent, :fletemoneda, :fleteorigen, :baseimponible2,');
  sqPedido.SQL.Add(':impuesto1porcent, :impuesto1monto, :impuesto2porcent, :impuesto2monto, :descuentocuadre');
  sqPedido.SQL.Add(')');

  // Asignar parámetros mejorados
  sqPedido.ParamByName('documento').AsString := NumeroPedido;
  sqPedido.ParamByName('tipo').AsInteger := 9; // Tipo de pedido
  sqPedido.ParamByName('status').AsInteger := 4; // Status como en el ejemplo
  sqPedido.ParamByName('visible').AsBoolean := True;
  sqPedido.ParamByName('fechaemision').AsDateTime := Now;
  sqPedido.ParamByName('depositosource').AsInteger := 1; // Valor por defecto
  sqPedido.ParamByName('depositodestino').AsInteger := 1; // Valor por defecto
  sqPedido.ParamByName('totalitems').AsInteger := TotalItems;
  sqPedido.ParamByName('totalitemsinicial').AsInteger := TotalItems;
  sqPedido.ParamByName('moneda').AsInteger := 1; // Moneda local
  sqPedido.ParamByName('factorcambio').AsFloat := 1.0;
  sqPedido.ParamByName('totalcosto').AsCurrency := TotalNeto; // Costo sin IVA
  sqPedido.ParamByName('totalcostoreal').AsCurrency := TotalNeto; // Costo real sin IVA
  sqPedido.ParamByName('totalbruto').AsCurrency := TotalBruto; // Total con IVA
  sqPedido.ParamByName('totalneto').AsCurrency := TotalBruto; // Total final con IVA
  sqPedido.ParamByName('baseimponible').AsCurrency := TotalNeto; // Base imponible sin IVA
  sqPedido.ParamByName('totalprecio').AsCurrency := TotalBruto; // Precio total con IVA
  sqPedido.ParamByName('clasificacion').AsInteger := 0; // Valor por defecto
  sqPedido.ParamByName('descripclasify').AsString := '<Ninguna>'; // Valor por defecto
  sqPedido.ParamByName('rifcliente').AsString := CodigoCliente;
  sqPedido.ParamByName('proposito').AsString := 'PEDIDO ICOMPRAS';
  sqPedido.ParamByName('responsable').AsString := CodigoCliente; // RIF o código del cliente
  sqPedido.ParamByName('user').AsInteger := 1; // Usuario del sistema
  sqPedido.ParamByName('autorizadopor').AsString := 'Crédito'; // Como en el ejemplo
  sqPedido.ParamByName('hora').AsTime := Time;
  sqPedido.ParamByName('tipoprecio').AsInteger := 1; // Precio de venta
  sqPedido.ParamByName('excento').AsBoolean := False;
  sqPedido.ParamByName('personacontacto').AsString := lblCliente.Caption;
  // Obtener teléfono del cliente desde el query
  if not sqCliente.IsEmpty then
    sqPedido.ParamByName('telefonocontacto').AsString := sqCliente.FieldByName('FC_TELEFONO').AsString
  else
    sqPedido.ParamByName('telefonocontacto').AsString := '';
  // Obtener dirección del cliente desde el query
  if not sqCliente.IsEmpty then
    sqPedido.ParamByName('direcciondespacho').AsString := sqCliente.FieldByName('FC_DIRECCION1').AsString
  else
    sqPedido.ParamByName('direcciondespacho').AsString := '';
  sqPedido.ParamByName('diasvencimiento').AsInteger := 15; // Como en el ejemplo
  sqPedido.ParamByName('fechavencido').AsDateTime := Now + 15; // 15 días de vencimiento
  sqPedido.ParamByName('tienelotes').AsBoolean := True; // Como solicitaste
  sqPedido.ParamByName('saldooperacion').AsCurrency := TotalBruto; // Monto total con IVA
  sqPedido.ParamByName('monedapago').AsInteger := 1; // 1 para BS, 2 para $
  sqPedido.ParamByName('machinename').AsString := GetEnvironmentVariable('COMPUTERNAME'); // Nombre del equipo
  sqPedido.ParamByName('factorreferencia').AsFloat := 1.0; // Valor por defecto, ajustar según sea necesario
  sqPedido.ParamByName('updateitems').AsBoolean := True; // Como en el ejemplo
  sqPedido.ParamByName('costodeventa').AsCurrency := TotalNeto; // Costo de venta sin IVA
  sqPedido.ParamByName('vendedorasignado').AsString := '31'; // Como en el ejemplo
  sqPedido.ParamByName('zonaventa').AsString := '01'; // Como en el ejemplo
  sqPedido.ParamByName('pendingforprint').AsBoolean := False; // Por defecto
  sqPedido.ParamByName('multiplevendedor').AsBoolean := False; // Por defecto
  sqPedido.ParamByName('multipledeposito').AsBoolean := False; // Por defecto
  sqPedido.ParamByName('timesaved').AsInteger := 0; // Por defecto
  // Parámetros de descuentos (todos en 0 por defecto)
  sqPedido.ParamByName('descuento1porcent').AsCurrency := 0;
  sqPedido.ParamByName('descuento1monto').AsCurrency := 0;
  sqPedido.ParamByName('descuento1origen').AsInteger := 1;
  sqPedido.ParamByName('descuento2porcent').AsCurrency := 0;
  sqPedido.ParamByName('descuento2monto').AsCurrency := 0;
  sqPedido.ParamByName('descuento2origen').AsInteger := 1;
  sqPedido.ParamByName('descuentoparcial').AsCurrency := 0;
  // Parámetros de flete (todos en 0 por defecto)
  sqPedido.ParamByName('fleteporcent').AsCurrency := 0;
  sqPedido.ParamByName('fletemoneda').AsCurrency := 0;
  sqPedido.ParamByName('fleteorigen').AsInteger := 1;
  sqPedido.ParamByName('baseimponible2').AsCurrency := 0;
  // Parámetros de impuestos calculados
  sqPedido.ParamByName('impuesto1porcent').AsCurrency := 16; // IVA 16%
  sqPedido.ParamByName('impuesto1monto').AsCurrency := TotalIVA; // Monto real del IVA calculado
  sqPedido.ParamByName('impuesto2porcent').AsCurrency := 0;
  sqPedido.ParamByName('impuesto2monto').AsCurrency := 0;
  sqPedido.ParamByName('descuentocuadre').AsCurrency := 0;

  sqPedido.ExecSQL;

  // Obtener el AutoIncrement de la cabecera recién insertada
  sqPedido.Close;
  sqPedido.SQL.Clear;
  sqPedido.SQL.Add('SELECT FTI_AUTOINCREMENT FROM SOperacionInv WHERE FTI_DOCUMENTO = :documento ORDER BY FTI_AUTOINCREMENT DESC');
  sqPedido.ParamByName('documento').AsString := NumeroPedido;
  sqPedido.Open;
  AutoIncrement := sqPedido.FieldByName('FTI_AUTOINCREMENT').AsInteger;
  sqPedido.Close;

  // Crear el detalle del pedido
  LineaDetalle := 0;
  cdsDetalle.First;
  while not cdsDetalle.Eof do
  begin
    CrearDetalleVenta(AutoIncrement, LineaDetalle, NumeroPedido, CodigoCliente);
    Inc(LineaDetalle);
    cdsDetalle.Next;
  end;

  ShowMessage('Pedido procesado correctamente.' + #13#10 +
              'Documento: ' + NumeroPedido + #13#10 +
              'Total Items: ' + IntToStr(TotalItems) + #13#10 +
              'Total Bruto: ' + FormatCurr('#,##0.00', TotalBruto) + #13#10 +
              'AutoIncrement: ' + IntToStr(AutoIncrement));
end;

