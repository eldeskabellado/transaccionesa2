procedure TformPedido.btnCargarClick(Sender: TObject);
begin
  try
    if dlgAbrir.Execute then
    begin
      // Extraer el número del pedido del nombre del archivo sin extensión
     // Pedido := ChangeFileExt(ExtractFileName(dlgAbrir.FileName), '');

      ProcesarArchivoPedido(dlgAbrir.FileName);
      ShowMessage('Archivo cargado correctamente: ' + IntToStr(cdsDetalle.RecordCount) + ' registros procesados.');
    end;
  except
    on E: Exception do
      ShowMessage('Error al cargar el archivo: ' + E.Message);
  end;
end;

procedure TformPedido.CargarDatosCliente(const CodigoCliente: string);
begin
  sqCliente.Close;
  sqCliente.SQL.Clear;
  sqCliente.SQL.Add('SELECT FC_CODIGO, FC_DESCRIPCION, FC_RIF, FC_DIRECCION1, FC_DIRECCION2,');
  sqCliente.SQL.Add('FC_TELEFONO, FC_CONTACTO, FC_ZONA, FC_DIASCREDITO, FC_STATUS,');
  sqCliente.SQL.Add('FC_LIMITECREDITO, FC_DIACORTE, FC_MAXIMODESCUENTO, FC_SALDO,');
  sqCliente.SQL.Add('FC_EMAIL, FC_PRECIODEFECTO, FC_SALDOMONEDA2, FC_VENDEDOR');
  sqCliente.SQL.Add('FROM SClientes');
  sqCliente.SQL.Add('WHERE FC_CODIGO = :codigo');
  sqCliente.SQL.Add('ORDER BY FC_DESCRIPCION');

  sqCliente.ParamByName('codigo').AsString := CodigoCliente;
  sqCliente.Open;

  if not sqCliente.IsEmpty then
  begin
    lblCliente.Caption := sqCliente.FieldByName('FC_DESCRIPCION').AsString;
    lblRif.Caption := sqCliente.FieldByName('FC_RIF').AsString;
  end
  else
  begin
    lblCliente.Caption := 'Cliente no encontrado';
    lblRif.Caption := '';
  end;
end;

constructor TformPedido.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  cdsDetalle := TClientDataSet.Create(Self);
  dsDetalle := TDataSource.Create(Self);
  dsDetalle.DataSet := cdsDetalle;
  DBGrid1.DataSource := dsDetalle;
  CrearDataSetDetalle;

  // Crear y configurar el diálogo de archivos
  dlgAbrir := TOpenDialog.Create(Self);
  dlgAbrir.Title := 'Seleccionar archivo de pedido';
  dlgAbrir.DefaultExt := 'txt';
  dlgAbrir.Filter := 'Archivos de texto (*.txt)|*.txt';
  dlgAbrir.FilterIndex := 1;
  dlgAbrir.InitialDir := 'C:\TP3\Descargas';
end;

destructor TformPedido.Destroy;
begin
  cdsDetalle.Free;
  dsDetalle.Free;
  dlgAbrir.Free;
  inherited Destroy;
end;

