procedure TformPedido.ConsultarDatosImpuestoArticulo(const CodigoArticulo: string; out TieneImpuesto: Boolean; out PorcentajeIVA: Double);
begin
  // Inicializar valores por defecto
  TieneImpuesto := False;
  PorcentajeIVA := 0;

  try
    sqArticulos.Close;
    sqArticulos.SQL.Clear;
    sqArticulos.SQL.Add('SELECT FIC_CODEITEM, FIC_IMP01EXENTO, FIC_IMP01MONTO');
    sqArticulos.SQL.Add('FROM a2InvCostosPrecios');
    sqArticulos.SQL.Add('WHERE FIC_CODEITEM = :codigo');

    sqArticulos.ParamByName('codigo').AsString := CodigoArticulo;
    sqArticulos.Open;

    if not sqArticulos.IsEmpty then
    begin
      // Verificar si el artículo tiene impuesto
      if (sqArticulos.FieldByName('FIC_IMP01MONTO').AsFloat > 0) and
         (not sqArticulos.FieldByName('FIC_IMP01EXENTO').AsBoolean) then
      begin
        TieneImpuesto := True;
        PorcentajeIVA := sqArticulos.FieldByName('FIC_IMP01MONTO').AsFloat;
      end;
    end;

    sqArticulos.Close;
  except
    on E: Exception do
    begin
      // En caso de error, asumir que no tiene impuesto
      TieneImpuesto := False;
      PorcentajeIVA := 0;
    end;
  end;
end;

procedure TformPedido.DBGrid1DblClick(Sender: TObject);
var
  CodigoArticulo: string;
  formLotes: TformLotes;
begin
  // Verificar que hay un registro seleccionado
  if cdsDetalle.IsEmpty then
  begin
    ShowMessage('No hay ningún artículo seleccionado.');
    Exit;
  end;

  try
    // Obtener el código del artículo seleccionado
    CodigoArticulo := cdsDetalle.FieldByName('CODPROD').AsString;

    // Crear y mostrar el formulario de lotes
    formLotes := TformLotes.Create(Self);
    try
      if formLotes.MostrarLotes(CodigoArticulo) = mrOk then
      begin
        // El usuario seleccionó un lote, actualizar el registro actual
        cdsDetalle.Edit;
        cdsDetalle.FieldByName('LOTE').AsString := formLotes.loteSeleccionado;
        cdsDetalle.FieldByName('VENCIMIENTO').AsString := formLotes.loteVencimiento;
        cdsDetalle.FieldByName('RANDON').AsString := IntToStr(formLotes.loteCodigoRandon);
        cdsDetalle.Post;

        ShowMessage('Lote asignado correctamente:' + #13#10 +
                   'Lote: ' + formLotes.loteSeleccionado + #13#10 +
                   'Vencimiento: ' + formLotes.loteVencimiento + #13#10 +
                   'Random: ' + IntToStr(formLotes.loteCodigoRandon));
      end;
      // Si el resultado es mrCancel, no hacer nada
    finally
      formLotes.Free;
    end;

  except
    on E: Exception do
      ShowMessage('Error al seleccionar lote: ' + E.Message);
  end;
end;

