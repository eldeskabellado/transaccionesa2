unit UnitConsulta;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Buttons, Vcl.StdCtrls, Data.DB,
  Vcl.Grids, Vcl.DBGrids, dbisamtb;

type
  TformConsulta = class(TForm)
    lblCodigo: TLabel;
    editCodigo: TEdit;
    btn2: TSpeedButton;
    lblPrecioDivisas1: TLabel;
    editPrecioDivisasConIva: TEdit;
    lblPrecio: TLabel;
    editPrecio: TEdit;
    DBGrid1: TDBGrid;
    SQBuscarPresentacion: TDBISAMQuery;
    SQBuscar: TDBISAMQuery;
    lblCapacidad: TLabel;
    editCapacidad: TEdit;
    ds1: TDataSource;
    lblCapacidad1: TLabel;
    lblCapacidad2: TLabel;
    lblFactor: TLabel;
    procedure btn2Click(Sender: TObject);
  private
    procedure ActualizarGridPresentaciones;
  public
    miIVASeleccionado: Currency;
    miCostoSeleccionado: Currency;
    miCostoBs: Currency;
    miPrecioSeleccionado: Currency;
    miPrecioBs: Currency;
    miPrecioDivisasSeleccionado: Currency;
    miFactor: Currency;
  end;

var
  formConsulta: TformConsulta;

implementation

uses
  UnitBuscarProductos, UnitDatos;

{$R *.dfm}

procedure TformConsulta.ActualizarGridPresentaciones;
var
  FactorStr: string;
begin
  if SQBuscarPresentacion.Active then
    SQBuscarPresentacion.Close;

  FactorStr := StringReplace(FloatToStr(miFactor), ',', '.', [rfReplaceAll]);

  SQBuscarPresentacion.SQL.Text :=
    'SELECT FO_CODE, FO_PRODUCTO, FO_DESCRIPCION, FO_PRECIODESC, ' +
    'FO_MTOIMPUESTO1, (FO_MTOTOTAL / ' + FactorStr + ') AS FO_MTOTOTAL, ' +
    'FO_UNDDESCARGA, FO_SOURCEIMP1, FO_VISIBLE ' +
    'FROM SinvOferta ' +
    'WHERE FO_PRODUCTO = :codigo AND FO_VISIBLE = TRUE';

  SQBuscarPresentacion.ParamByName('codigo').AsString := editCodigo.Text;

  try
    SQBuscarPresentacion.Open;

    // Formatear el campo FO_UNDDESCARGA si existe
    if SQBuscarPresentacion.FindField('FO_UNDDESCARGA') <> nil then
    begin
      TFloatField(SQBuscarPresentacion.FieldByName('FO_UNDDESCARGA')).DisplayFormat := '#,##0.00';
      TFloatField(SQBuscarPresentacion.FieldByName('FO_UNDDESCARGA')).Currency := False;
    end;

    // Formatear el campo FO_MTOTOTAL si existe
    if SQBuscarPresentacion.FindField('FO_MTOTOTAL') <> nil then
    begin
      TFloatField(SQBuscarPresentacion.FieldByName('FO_MTOTOTAL')).DisplayFormat := '#,##0.0000';
      TFloatField(SQBuscarPresentacion.FieldByName('FO_MTOTOTAL')).Currency := False;
    end;

  except
    on E: Exception do
      ShowMessage('Error actualizando presentaciones: ' + E.Message);
  end;
end;

procedure TformConsulta.btn2Click(Sender: TObject);
var
  formBuscar: TformBuscarArticulo;
begin
  formBuscar := TformBuscarArticulo.Create(Self);
  try
    if formBuscar.ShowModal = mrOk then
    begin
      editCodigo.Text := formBuscar.CodigoSeleccionado;
      editPrecioDivisasConIva.Text := FormatFloat('0.0000', formBuscar.DivisasSeleccionado * 1.16);
      editPrecio.Text := FormatFloat('0.0000', (formBuscar.DivisasSeleccionado * 1.16) * mifactor);
      editCapacidad.Text := FormatFloat('0.00', formBuscar.CapacidadSeleccionado);

      // Actualizar grid de presentaciones
      ActualizarGridPresentaciones;

      // Llenar variables adicionales si es necesario
      miPrecioDivisasSeleccionado := formBuscar.DivisasSeleccionado;
    end;
  finally
    formBuscar.Free;
  end;
end;

end.
