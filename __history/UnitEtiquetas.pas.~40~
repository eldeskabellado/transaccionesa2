// ================================
// FUNCIONAMIENTO OPTIMIZADO:
// ================================
// btn1: Imprimir TODAS las ofertas (FO_UNDDESCARGA = 1) + buscar sus presentaciones en AMBAS tablas
// btnImpTodos: Imprimir TODO el inventario (FI_STATUS = TRUE) + buscar sus presentaciones
// sqDetalleEtiqueta: Para presentaciones de OFERTAS (FO_UNDDESCARGA <> 1)
// sqDetalleEtiquetaInventario: Para presentaciones de INVENTARIO (FI_CAPACIDAD <> 1)
// OFERTAS: Precio calculado en query (FO_MTOTOTAL / TasaMoneda)
// INVENTARIO: Precio directo de tabla costos (ya en divisas)
// ================================

function TformEtiquetas.ObtenerTasaMoneda: Double;
begin
  Result := 30.0; // Valor por defecto

  try
    with sqTasa do
    begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT FM_FACTOR FROM smoneda WHERE FM_CODE = 2');

      try
        Open;
        if not EOF and not FieldByName('FM_FACTOR').IsNull then
        begin
          Result := FieldByName('FM_FACTOR').AsFloat;
          if Result <= 0 then
            Result := 30.0;
        end
        else
        begin
          // Intentar con FM_CODE como string
          Close;
          SQL.Clear;
          SQL.Add('SELECT FM_FACTOR FROM smoneda WHERE FM_CODE = ''2''');
          Open;
          if not EOF and not FieldByName('FM_FACTOR').IsNull then
          begin
            Result := FieldByName('FM_FACTOR').AsFloat;
            if Result <= 0 then
              Result := 30.0;
          end;
        end;
        Close;
      except
        on E: Exception do
        begin
          Result := 30.0;
          ShowMessage('Error obteniendo tasa: ' + E.Message + '. Usando tasa por defecto: 30.0');
        end;
      end;
    end;
  except
    on E: Exception do
    begin
      Result := 30.0;
      ShowMessage('Error general obteniendo tasa: ' + E.Message + '. Usando tasa por defecto: 30.0');
    end;
  end;

  FTasaMoneda := Result;
end;

