  lblPrecioHeader.Caption := 'Precio';
  lblPaqueteHeader.Caption := 'Paquete Nota';
  lblGananciaDivisaHeader.Caption := 'Ganancia/Divisa';
  lblBulto.Caption := 'Bulto';
  lblPrecio1.Caption := 'Precio 1';
