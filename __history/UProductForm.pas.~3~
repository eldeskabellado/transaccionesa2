var
  frmProducto: TfrmProducto;

implementation

{$R *.dfm}

procedure TfrmProducto.FormCreate(Sender: TObject);
begin
  // Configurar RadioGroup de idioma
  rgIdioma.Items.Clear;
  rgIdioma.Items.Add('Espańol');
  rgIdioma.Items.Add('????'); // Chino tradicional
  rgIdioma.ItemIndex := 0; // Por defecto espańol

  // Configurar combobox de categorías
  cmbCategoria.Items.Clear;
  cmbCategoria.Items.Add('QUINCALLERIA');
  cmbCategoria.Items.Add('FERRETERIA');
  cmbCategoria.Items.Add('ELECTRICIDAD');
  cmbCategoria.Items.Add('PLOMERIA');
  cmbCategoria.ItemIndex := 0;

  // Configurar valores por defecto
  edtIVA.Text := '16%';
  edtDivisa1.Text := '1.000';
  edtGanancia1.Text := '800.00%';
  edtDivisa2.Text := '9.000';

  // Configurar idioma inicial
  ConfigurarIdioma;
end;

procedure TfrmProducto.rgIdiomaClick(Sender: TObject);
begin
  ConfigurarIdioma;
end;

procedure TfrmProducto.ConfigurarIdioma;
begin
  if rgIdioma.ItemIndex = 0 then
    ConfigurarIdiomaEspanol
  else
    ConfigurarIdiomaChino;
end;

