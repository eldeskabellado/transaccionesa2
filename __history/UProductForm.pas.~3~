procedure TfrmProducto.chkAutomatico1Click(Sender: TObject);
begin
  if chkAutomatico1.Checked then
    CalcularPrecios;
end;

procedure TfrmProducto.chkAutomatico2Click(Sender: TObject);
begin
  if chkAutomatico2.Checked then
    CalcularPrecios;
end;

procedure TfrmProducto.CalcularPrecios;
var
  Costo, Ganancia, Precio: Double;
begin
  // Calcular precio automáticamente basado en costo y ganancia
  try
    if TryStrToFloat(StringReplace(edtCosto.Text, '%', '', [rfReplaceAll]), Costo) and
       TryStrToFloat(StringReplace(edtGanancia1.Text, '%', '', [rfReplaceAll]), Ganancia) then
    begin
      Precio := Costo * (1 + (Ganancia / 100));
      edtPrecio.Text := FormatFloat('0.00', Precio);
    end;
  except
    // Manejo de errores en caso de valores inválidos
  end;
end;

procedure TfrmProducto.btnAceptarClick(Sender: TObject);
begin
  // Validaciones básicas
  if Trim(edtCodigo.Text) = '' then
  begin
    ShowMessage('El código es obligatorio');
    edtCodigo.SetFocus;
    Exit;
  end;

  if Trim(edtDescripcion.Text) = '' then
  begin
    ShowMessage('La descripción es obligatoria');
    edtDescripcion.SetFocus;
    Exit;
  end;

  // Aquí iría la lógica para guardar los datos
  ShowMessage('Producto guardado exitosamente');
  ModalResult := mrOk;
end;

procedure TfrmProducto.btnCancelarClick(Sender: TObject);
begin
  ModalResult := mrCancel;
end;

end.
