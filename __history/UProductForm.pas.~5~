  rgIdioma.Items.Add('Español');
  rgIdioma.Items.Add('中文繁體');
  rgIdioma.ItemIndex := 0;

  // Configurar combobox de categorías
  cmbCategoria.Items.Clear;
  cmbCategoria.Items.Add('QUINCALLERIA');
  cmbCategoria.Items.Add('FERRETERIA');
  cmbCategoria.Items.Add('ELECTRICIDAD');
  cmbCategoria.Items.Add('PLOMERIA');
  cmbCategoria.ItemIndex := 0;

  // Configurar valores por defecto
  edtCodigo.Text := 'C-644';
  edtDescripcion.Text := 'ACCESORIO DE DAMA 5565';
  edtIVA.Text := '16%';
  edtCosto.Text := '36.00';
  edtPrecio.Text := '909.72';
  edtDivisa1.Text := '1.000';
  edtGanancia1.Text := '800.00%';
  edtDivisa2.Text := '9.000';

  // Configurar idioma inicial (esto aplicará todos los acentos correctamente)
  ConfigurarIdioma;
end;

procedure TfrmProducto.rgIdiomaClick(Sender: TObject);
begin
