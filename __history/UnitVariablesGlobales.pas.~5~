unit UnitVariablesGlobales;

interface

uses
  System.SysUtils;  // Necesario para ExtractFilePath

var
  // Variables globales para iCompras360
  TasaCambiaria: Double;        // Factor cambiario del día
  RIFEmpresa: string = '500726856';     // RIF de la empresa (solo números)
  NombreEmpresa: string = 'DROGUERIA EL AMPARO, C.A.';
  CodigoProveedor: string = 'J500726856'; // RIF completo para proveedor

  // Configuración TP3
  RutaArchivosTP3: string = '';         // Se inicializa en runtime
  GenerandoArchivo: Boolean = False;    // Control de proceso en curso

  // Configuración de archivos
  NombreArchivoInventario: string = 'inventario.txt';
  NombreArchivoClientes: string = 'clientes.txt';

  // Control de hilos
  ProcesoEnCurso: Boolean = False;
  Host : string;
  Port : Integer;
  Username : string;
  Password : string;
  Passive : Boolean = True;
  ConnectTimeout : Integer = 30000;
  ReadTimeout : Integer = 60000;


implementation

initialization
  // Inicializar ruta por defecto
  RutaArchivosTP3 := ExtractFilePath(ParamStr(0)) + 'TP3\';

end.
