procedure TformArticulos.GuardarProducto;
begin
  try
    if not tProductos.Active then tProductos.Open;

    if tProductos.Locate('FI_CODIGO', editCodigo.Text, []) then
      tProductos.Edit
    else
      tProductos.Append;

    tProductos.FieldByName('FI_CODIGO').AsString := editCodigo.Text;
    tProductos.FieldByName('FI_DESCRIPCION').AsString := editNombre.Text;
    tProductos.FieldByName('FI_CATEGORIA').AsString := '01';
    tProductos.FieldByName('FI_DESCRIPCIONDETALLADA').AsString := editDetalle.Text;
    tProductos.FieldByName('FI_STATUS').AsBoolean := True;
    tProductos.FieldByName('FI_CAPACIDAD').AsFloat := CapacidadSeleccionado;
    tProductos.FieldByName('FI_MONEDA').AsString := '2';
    tProductos.FieldByName('FI_SUBCATEGORIA').AsString := edtCATEGORIA.Text;
    tProductos.Post;
  except
    on E: Exception do
    begin
      if tProductos.State in [dsEdit, dsInsert] then tProductos.Cancel;
      raise Exception.Create('Error guardando producto: ' + E.Message);
    end;
  end;
end;

procedure TformArticulos.GuardarCostos;
var
  precioSinImpuesto, montoIVA: Double;
begin
  try
    precioSinImpuesto := miPrecioSeleccionado / 1.16;
    montoIVA := miPrecioSeleccionado - precioSinImpuesto;

    if not tCostos.Active then tCostos.Open;

    if tCostos.Locate('FIC_CODEITEM', editCodigo.Text, []) then
      tCostos.Edit
    else
      tCostos.Append;

    tCostos.FieldByName('FIC_CODEITEM').AsString := editCodigo.Text;
    tCostos.FieldByName('FIC_IMP01ACTIVO').AsBoolean := True;
    tCostos.FieldByName('FIC_IMP01PORCENT').AsBoolean := True;
    tCostos.FieldByName('FIC_IMP01MONTO').AsFloat := miIVASeleccionado;
    tCostos.FieldByName('FIC_IMP02MONTO').AsFloat := 8;
    tCostos.FieldByName('FIC_COSTOACTBOLIVARES').AsFloat := miCostoBs;
    tCostos.FieldByName('FIC_COSTOANTBOLIVARES').AsFloat := miCostoBs;
    tCostos.FieldByName('FIC_COSTOANTEXTRANJERO').AsFloat := miCostoSeleccionado;
    tCostos.FieldByName('FIC_COSTOACTEXTRANJERO').AsFloat := miCostoSeleccionado;
    tCostos.FieldByName('FIC_COSTOPROMEDIOEXTRANJERO').AsFloat := miCostoSeleccionado;
    tCostos.FieldByName('FIC_COSTOREFERENCIA').AsFloat := miCostoSeleccionado;
    tCostos.FieldByName('FIC_P01UTILIDAD').AsFloat := miUtilidad;
    tCostos.FieldByName('FIC_P01PRECIOSINIMPUESTO').AsFloat := precioSinImpuesto;
    tCostos.FieldByName('FIC_P01IMTOIMPUESTO01').AsFloat := montoIVA;
    tCostos.FieldByName('FIC_P01IPRECIOTOTAL').AsFloat := miPrecioSeleccionado;
    tCostos.FieldByName('FIC_P01PORCENTUTILIDADEXT').AsBoolean := True;
    tCostos.FieldByName('FIC_P01UTILIDADEXT').AsFloat := miUtilidad;
    tCostos.FieldByName('FIC_P01PRECIOTOTALEXT').AsFloat := miPrecioDivisasSeleccionado;
    tCostos.Post;
  except
    on E: Exception do
    begin
      if tCostos.State in [dsEdit, dsInsert] then tCostos.Cancel;
      raise Exception.Create('Error guardando costos: ' + E.Message);
    end;
  end;
end;

procedure TformArticulos.GuardarSfixed;
begin
  try
    if not tSfixed.Active then tSfixed.Open;

    if tSfixed.Locate('FX_CODIGO', editCodigo.Text, []) then
      tSfixed.Edit
    else
      tSfixed.Append;

    tSfixed.FieldByName('FX_TIPO').AsString := 'B';
    tSfixed.FieldByName('FX_CODIGO').AsString := editCodigo.Text;
    tSfixed.FieldByName('FX_VISIBLE').AsBoolean := True;
    tSfixed.FieldByName('FX_HASOPERATIONS').AsBoolean := True;
    tSfixed.Post;
  except
    on E: Exception do
    begin
      if tSfixed.State in [dsEdit, dsInsert] then tSfixed.Cancel;
      raise Exception.Create('Error guardando en SFIXED: ' + E.Message);
    end;
  end;
end;

procedure TformArticulos.GuardarArticuloCompleto;
begin
  try
    if Trim(editCodigo.Text) = '' then
    begin
      ShowMessage('Error: Debe especificar el código del producto');
      editCodigo.SetFocus; Exit;
    end;

    if Trim(editNombre.Text) = '' then
    begin
      ShowMessage('Error: Debe especificar la descripción del producto');
      editNombre.SetFocus; Exit;
    end;

    if miCostoSeleccionado <= 0 then
    begin
      ShowMessage('Error: Debe especificar un costo válido');
      editDivisas.SetFocus; Exit;
    end;

    if CapacidadSeleccionado <= 0 then
    begin
      ShowMessage('Error: Debe especificar la capacidad del bulto');
      editCapacidad.SetFocus; Exit;
    end;

    GuardarProducto;
    GuardarCostos;
    GuardarSfixed;
    GuardarCodigosAsociados;
    ActualizarGridPresentaciones;

    if accion = 1 then
      ShowMessage('Artículo guardado exitosamente: ' + editCodigo.Text)
    else
      ShowMessage('Artículo actualizado exitosamente: ' + editCodigo.Text);

    if accion = 1 then btn3Click(nil);
  except
    on E: Exception do
      ShowMessage('Error al guardar el artículo: ' + E.Message);
  end;
end;

