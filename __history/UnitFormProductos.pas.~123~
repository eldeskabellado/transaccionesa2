      Exit;

    sqEliminar := TDBISAMQuery.Create(Self);
    try
      sqEliminar.DatabaseName := SQBuscarPresentacion.DatabaseName;

      // USAR ELIMINACIÓN FÍSICA DIRECTA
      sqEliminar.SQL.Text := 'DELETE FROM SinvOferta WHERE FO_PRODUCTO = ' + QuotedStr(editCodigo.Text);
      sqEliminar.ExecSQL;

