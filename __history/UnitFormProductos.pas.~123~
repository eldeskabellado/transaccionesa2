procedure TformArticulos.HabilitarControles(Estado: Integer);
begin
  case Estado of
    0: begin
      editCodigo.Clear; editCodigo.Enabled := False;
      editNombre.Clear; editNombre.Enabled := False;
      cmb1.Text := ''; cmb1.Enabled := False;
      editIVA.Clear; editIVA.Enabled := False;
      editCosto.Clear; editCosto.Enabled := False;
      editDivisas.Clear; editDivisas.Enabled := False;
      editUtilidad.Clear; editUtilidad.Enabled := False;
      editPrecio.Clear; editPrecio.Enabled := False;
      editPrecioDivisas.Clear; editPrecioDivisas.Enabled := False;
      editDetalle.Clear; editDetalle.Enabled := False;
      btnGUARDAR.Enabled := False;
      editCapacidad.Text := '1'; editCapacidad.Enabled := False;
      edtCATEGORIA.Clear; edtCATEGORIA.Enabled := False;
    end;
    1, 2: begin
      editCodigo.Enabled := True; editNombre.Enabled := True;
      cmb1.Enabled := True; editIVA.Enabled := True;
      editCosto.Enabled := True; editDivisas.Enabled := True;
      editUtilidad.Enabled := True; editPrecio.Enabled := True;
      editPrecioDivisas.Enabled := True; editDetalle.Enabled := True;
      btnGUARDAR.Enabled := True; editCapacidad.Text := '1';
      editCapacidad.Enabled := True; edtCATEGORIA.Enabled := True;
      if Estado = 1 then editCodigo.SetFocus;
    end;
  end;
end;

