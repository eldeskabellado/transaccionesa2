// Método alternativo para llamar desde e
procedure TformArticulos.ImprimirEtiqueta(const CodigoProducto: string);
var
  SQLText: string;
  SQLTextInventario: string;
  tasastr: string;
begin
  // Ubicamos la unidad detallada - CORREGIDO: Agregada condición por código
  SQLTextInventario := 'SELECT I.FI_CODIGO, I.FI_DESCRIPCION, I.FI_STATUS, ' +
                       'I.FI_UNIDAD, I.FI_CAPACIDAD, C.FIC_P01PRECIOTOTALEXT ' +
                       'FROM SINVENTARIO AS I ' +
                       'INNER JOIN a2InvCostosPrecios AS C ON I.FI_CODIGO = C.FIC_CODEITEM ' +
                       'WHERE I.FI_STATUS = TRUE AND I.FI_CAPACIDAD = 1 ' +
                       'AND I.FI_CODIGO = ' + QuotedStr(CodigoProducto);

  with sqInventario do
  begin
    Close;
    SQL.Clear;
    SQL.Add(SQLTextInventario);
    Open;
  end;

  with sqPresentacion do
  begin
    SQL.Clear;
    TasaStr := StringReplace(FloatToStr(miFactor), ',', '.', [rfReplaceAll]);
    SQLText := 'SELECT FO_PRODUCTO, FO_DESCRIPCION, FO_UNDDESCARGA, ' +
               '(FO_MTOTOTAL / 110.56) AS FO_MTOTOTAL ' +
               'FROM sinvoferta ' +
               'WHERE FO_VISIBLE = TRUE AND FO_UNDDESCARGA = 1 ' +
               'AND FO_PRODUCTO = ' + QuotedStr(CodigoProducto) +
               ' ORDER BY FO_UNDDESCARGA';
    SQL.Add(SQLText);
    Open;
  end;

  // Consulta para etiquetas de inventario con capacidad <> 1
  with sqDetalleetiquetaInventario do
  begin
    Close;
    SQL.Clear;
    SQLTextInventario := 'SELECT I.FI_CODIGO, I.FI_DESCRIPCION, I.FI_STATUS, ' +
                         'I.FI_UNIDAD, I.FI_CAPACIDAD, C.FIC_P01PRECIOTOTALEXT ' +
                         'FROM SINVENTARIO AS I ' +
                         'INNER JOIN a2InvCostosPrecios AS C ON I.FI_CODIGO = C.FIC_CODEITEM ' +
                         'WHERE I.FI_STATUS = TRUE AND I.FI_CAPACIDAD <> 1 ' +
                         'AND I.FI_CODIGO = ' + QuotedStr(CodigoProducto);
    SQL.Add(SQLTextInventario);
    Open;
  end;

  // Consulta para etiquetas de presentaciones con FO_UNDDESCARGA <> 1
  with sqDetEtiquetasPresentaciones do
  begin
    Close;
    SQL.Clear;
    SQLText := 'SELECT FO_PRODUCTO, FO_DESCRIPCION, FO_UNDDESCARGA, ' +
               '(FO_MTOTOTAL / 110.56) AS FO_MTOTOTAL ' +
               'FROM sinvoferta ' +
               'WHERE FO_VISIBLE = TRUE AND FO_UNDDESCARGA <> 1 ' +
               'AND FO_PRODUCTO = ' + QuotedStr(CodigoProducto) +
               ' ORDER BY FO_UNDDESCARGA';
    SQL.Add(SQLText);
    Open;
  end;

  // Lógica para mostrar el reporte correspondiente
  if sqInventario.RecordCount > 0 then
  begin
    // Mostrar reporte de inventario
    ShowMessage('Desde Productos');
    frpInventario.ShowReport;
  end
  else if sqPresentacion.RecordCount > 0 then
  begin
    // Mostrar reporte de presentaciones
     ShowMessage('Desde {ProductosPresentaciones');
    frpPresentaciones.ShowReport;
  end;
end;

procedure TformArticulos.ImprimirEtiquetasDesdeGrid;
var
  CodigoSeleccionado: string;
begin
  if not DBGrid1.DataSource.DataSet.Active then
  begin
    ShowMessage('No hay datos activos en el grid');
    Exit;
  end;

  if DBGrid1.DataSource.DataSet.IsEmpty then
  begin
    ShowMessage('No hay registros seleccionados');
    Exit;
  end;

  // Obtener código del grid actual (ajustar el nombre del campo según tu tabla)
  try
    CodigoSeleccionado := DBGrid1.DataSource.DataSet.FieldByName('CODIGO').AsString;
    if CodigoSeleccionado = '' then
      CodigoSeleccionado := DBGrid1.DataSource.DataSet.FieldByName('FI_CODIGO').AsString;
  except
    ShowMessage('No se pudo obtener el código del registro seleccionado');
    Exit;
  end;

  if CodigoSeleccionado <> '' then
    ProcesarEtiquetas(CodigoSeleccionado)
  else
    ShowMessage('El código seleccionado está vacío');
end;

// Método alternativo para llamar desde código



procedure TformArticulos.CalcularDesdeCosoBS;
begin
  if miUtilidad = 0 then
    miPrecioSeleccionado := miCostoSeleccionado
  else
    miPrecioSeleccionado := miCostoSeleccionado * (1 + (miUtilidad / 100));

  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.CalcularDesdeIVA;
begin
  miPrecioSinImpuesto := miPrecioSeleccionado / (1 + (miIVASeleccionado / 100));
  miPrecioSinImpuestoDivisas := miPrecioSinImpuesto / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.CalcularDesdeCostoDivisas;
var
  costoDivisas: Currency;
begin
  costoDivisas := StrToFloatDef(StringReplace(editDivisas.Text, ',', '', [rfReplaceAll]), 0);
  miCostoSeleccionado := costoDivisas * miFactor;
  miPrecioSeleccionado := miCostoSeleccionado * (1 + (miUtilidad / 100));
  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.CalcularDesdePrecio;
begin
  if miCostoSeleccionado > 0 then
    miUtilidad := ((miPrecioSeleccionado - miCostoSeleccionado) / miCostoSeleccionado) * 100
  else
    miUtilidad := 0;
  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.CalcularUtilidadSolamente;
begin
  if miUtilidad = 0 then
    miPrecioSeleccionado := miCostoBs
  else
    miPrecioSeleccionado := miCostoBs * (1 + (miUtilidad / 100));
  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.FormatearEdits;
begin
  editCosto.Text := FormatFloat('#,##0.00', miCostoBs);
  editPrecio.Text := FormatFloat('#,##0.00', miPrecioSeleccionado);
  editIVA.Text := FormatFloat('#,##0.00', miIVASeleccionado);
  editDivisas.Text := FormatFloat('#,##0.0000', miCostoSeleccionado);
  editPrecioDivisas.Text := FormatFloat('#,##0.0000', miPrecioDivisasSeleccionado);
  editUtilidad.Text := FormatFloat('#,##0.00', miUtilidad) + '%';
  miPrecioSinImpuesto := miPrecioSeleccionado / (1 + (miIVASeleccionado / 100));
  miPrecioSinImpuestoDivisas := miPrecioSinImpuesto / miFactor;
end;

