procedure TformArticulos.AgregarCodigoAsociado;
var
  i: Integer;
  codigoExiste: Boolean;
begin
  try
    codigoExiste := False;
    for i := 0 to Length(ArrayCodigosAsociados) - 1 do
    begin
      if ArrayCodigosAsociados[i] = edtCodAsociado.Text then
      begin
        codigoExiste := True; Break;
      end;
    end;

    if codigoExiste then
    begin
      ShowMessage('El código ya está en la lista.');
      edtCodAsociado.SelectAll; Exit;
    end;

    SetLength(ArrayCodigosAsociados, Length(ArrayCodigosAsociados) + 1);
    ArrayCodigosAsociados[Length(ArrayCodigosAsociados) - 1] := edtCodAsociado.Text;
    ShowMessage('Código agregado. Total: ' + IntToStr(Length(ArrayCodigosAsociados)));
    edtCodAsociado.Clear; edtCodAsociado.SetFocus;
    Self.Caption := 'Artículos - Códigos: ' + IntToStr(Length(ArrayCodigosAsociados));
  except
    on E: Exception do
      ShowMessage('Error agregando código: ' + E.Message);
  end;
end;

procedure TformArticulos.GuardarCodigosAsociados;
var
  i: Integer;
begin
  try
    if not tCodAsociado.Active then tCodAsociado.Open;

    for i := 0 to Length(ArrayCodigosAsociados) - 1 do
    begin
      if not CodigoAsociadoExiste(ArrayCodigosAsociados[i]) then
      begin
        tCodAsociado.Append;
        tCodAsociado.FieldByName('FBARRA_CODE').AsString := ArrayCodigosAsociados[i];
        tCodAsociado.FieldByName('FBARRA_PRODUCTO').AsString := editCodigo.Text;
        tCodAsociado.FieldByName('FBARRA_TIPO').AsInteger := 0;
        tCodAsociado.Post;
      end;
    end;
    LimpiarArrayCodigos;
  except
    on E: Exception do
    begin
      if tCodAsociado.State in [dsEdit, dsInsert] then tCodAsociado.Cancel;
      raise Exception.Create('Error guardando códigos: ' + E.Message);
    end;
  end;
end;

procedure TformArticulos.GuardarCodigoDirecto(codigo: string);
begin
  try
    if CodigoAsociadoExiste(codigo) then
    begin
      ShowMessage('El código ya está asociado.');
      edtCodAsociado.SelectAll; Exit;
    end;

    if not tCodAsociado.Active then tCodAsociado.Open;

    tCodAsociado.Append;
    tCodAsociado.FieldByName('FBARRA_CODE').AsString := codigo;
    tCodAsociado.FieldByName('FBARRA_PRODUCTO').AsString := editCodigo.Text;
    tCodAsociado.FieldByName('FBARRA_TIPO').AsInteger := 0;
    tCodAsociado.Post;

    ShowMessage('Código guardado exitosamente.');
    edtCodAsociado.Clear; edtCodAsociado.SetFocus;
    if accion = 2 then RefrescarGridCodigosAsociados;
  except
    on E: Exception do
    begin
      if tCodAsociado.State in [dsEdit, dsInsert] then tCodAsociado.Cancel;
      ShowMessage('Error guardando código: ' + E.Message);
    end;
  end;
end;

function TformArticulos.CodigoAsociadoExiste(codigo: string): Boolean;
begin
  Result := False;
  try
    if not tCodAsociado.Active then tCodAsociado.Open;
    tCodAsociado.First;
    while not tCodAsociado.Eof do
    begin
      if (tCodAsociado.FieldByName('FBARRA_CODE').AsString = codigo) and
         (tCodAsociado.FieldByName('FBARRA_PRODUCTO').AsString = editCodigo.Text) then
      begin
        Result := True; Break;
      end;
      tCodAsociado.Next;
    end;
  except
    on E: Exception do
      ShowMessage('Error verificando código: ' + E.Message);
  end;
end;

procedure TformArticulos.LimpiarArrayCodigos;
begin
  SetLength(ArrayCodigosAsociados, 0);
  Self.Caption := 'Artículos';
end;

procedure TformArticulos.MostrarCodigosEnArray;
var
  i: Integer;
  lista: string;
begin
  if Length(ArrayCodigosAsociados) = 0 then
    lista := 'No hay códigos en la lista'
  else
  begin
    lista := 'Códigos en la lista:' + sLineBreak;
    for i := 0 to Length(ArrayCodigosAsociados) - 1 do
      lista := lista + IntToStr(i + 1) + '. ' + ArrayCodigosAsociados[i] + sLineBreak;
  end;
  ShowMessage(lista);
end;

function TformArticulos.ValidarCodigoAsociado: Boolean;
begin
  Result := True;
  if Trim(editCodigo.Text) = '' then
  begin
    ShowMessage('Debe tener un código de producto.');
    Result := False; Exit;
  end;

  if Trim(edtCodAsociado.Text) = '' then
  begin
    ShowMessage('Debe ingresar un código asociado.');
    edtCodAsociado.SetFocus; Result := False; Exit;
  end;
end;

procedure TformArticulos.RefrescarGridCodigosAsociados;
begin
  try
    if sqCodAsociado.Active then sqCodAsociado.Close;
    sqCodAsociado.SQL.Text := 'SELECT FBARRA_CODE, FBARRA_PRODUCTO, FBARRA_TIPO FROM sCodeBar WHERE FBARRA_PRODUCTO = :producto ORDER BY FBARRA_CODE';
    sqCodAsociado.ParamByName('producto').AsString := editCodigo.Text;
    sqCodAsociado.Open;
  except
    on E: Exception do
      ShowMessage('Error refrescando códigos: ' + E.Message);
  end;
end;

