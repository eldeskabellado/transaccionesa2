procedure TformArticulos.EliminarCodigoAsociadoSeleccionado;
var
  codigoAsociado, productoAsociado: string;
  sqEliminar: TDBISAMQuery;
begin
  try
    if sqCodAsociado.IsEmpty then
    begin
      ShowMessage('No hay código asociado seleccionado para eliminar.');
      Exit;
    end;

    // Solo permitir en modo MODIFICAR
    if accion <> 2 then
    begin
      ShowMessage('Solo se pueden eliminar códigos asociados en modo MODIFICAR.');
      Exit;
    end;

    codigoAsociado := sqCodAsociado.FieldByName('FBARRA_CODE').AsString;
    productoAsociado := sqCodAsociado.FieldByName('FBARRA_PRODUCTO').AsString;

    // Validar que el código no sea igual al código del producto principal
    if codigoAsociado = editCodigo.Text then
    begin
      if MessageDlg(
        'ATENCIÓN: Está intentando eliminar el código principal del producto.' + sLineBreak +
        'Código: ' + codigoAsociado + sLineBreak + sLineBreak +
        '¿Está seguro que desea continuar?',
        mtWarning, [mbYes, mbNo], 0) = mrNo then
        Exit;
    end;

    if MessageDlg(
      'ELIMINAR CÓDIGO ASOCIADO' + sLineBreak + sLineBreak +
      'Código: ' + codigoAsociado + sLineBreak +
      'Producto: ' + productoAsociado + sLineBreak + sLineBreak +
      '¿Está seguro que desea eliminar este código asociado?',
      mtConfirmation, [mbYes, mbNo], 0) = mrNo then
      Exit;

    sqEliminar := TDBISAMQuery.Create(Self);
    try
      sqEliminar.DatabaseName := sqCodAsociado.DatabaseName;

      // Eliminar el código asociado específico
      sqEliminar.SQL.Text :=
        'DELETE FROM sCodeBar WHERE FBARRA_CODE = ' + QuotedStr(codigoAsociado) +
        ' AND FBARRA_PRODUCTO = ' + QuotedStr(productoAsociado);

      sqEliminar.ExecSQL;

      if sqEliminar.RowsAffected > 0 then
      begin
        ShowMessage('Código asociado eliminado exitosamente: ' + codigoAsociado);
        RefrescarGridCodigosAsociados;
      end
      else
        ShowMessage('No se pudo eliminar el código asociado.');
    finally
      sqEliminar.Free;
    end;
  except
    on E: Exception do
      ShowMessage('Error eliminando código asociado: ' + E.Message);
  end;
end;
