procedure TformArticulos.ActualizarGridPresentaciones;
begin
  if SQBuscarPresentacion.Active then
    SQBuscarPresentacion.Close;

  SQBuscarPresentacion.SQL.Text :=
    'SELECT FO_CODE, FO_PRODUCTO, FO_DESCRIPCION, FO_PRECIODESC, ' +
    'FO_MTOIMPUESTO1, FO_MTOTOTAL, FO_UNDDESCARGA, FO_SOURCEIMP1, FO_VISIBLE ' +
    'FROM SinvOferta ' +
    'WHERE FO_PRODUCTO = :codigo AND FO_VISIBLE = TRUE';

  SQBuscarPresentacion.ParamByName('codigo').AsString := editCodigo.Text;

  try
    SQBuscarPresentacion.Open;
    if SQBuscarPresentacion.FindField('FO_UNDDESCARGA') <> nil then
    begin
      TFloatField(SQBuscarPresentacion.FieldByName('FO_UNDDESCARGA')).DisplayFormat := '#,##0.00';
      TFloatField(SQBuscarPresentacion.FieldByName('FO_UNDDESCARGA')).Currency := False;
    end;
  except
    on E: Exception do
      ShowMessage('Error actualizando presentaciones: ' + E.Message);
  end;
end;

// REEMPLAZAR EL PROCEDIMIENTO EliminarPresentacionSeleccionada CON ESTA VERSIÓN:
// (Usando la misma sintaxis que funciona en EliminarTodasLasPresentaciones)

// REEMPLAZAR EL PROCEDIMIENTO EliminarPresentacionSeleccionada CON ESTA VERSIÓN:
// FO_CODE es NUMÉRICO, no usar QuotedStr()

procedure TformArticulos.EliminarPresentacionSeleccionada;
var
  codigoPresentacion, descripcionPresentacion: string;
  precioPresentacion: Currency;
  sqEliminar: TDBISAMQuery;
begin
  try
    if SQBuscarPresentacion.IsEmpty then
    begin
      ShowMessage('No hay presentación seleccionada para eliminar.');
      Exit;
    end;

    codigoPresentacion := SQBuscarPresentacion.FieldByName('FO_CODE').AsString;
    descripcionPresentacion := SQBuscarPresentacion.FieldByName('FO_DESCRIPCION').AsString;

    if SQBuscarPresentacion.FindField('FO_MTOTOTAL') <> nil then
      precioPresentacion := SQBuscarPresentacion.FieldByName('FO_MTOTOTAL').AsCurrency
    else
      precioPresentacion := 0;

    if MessageDlg(
      'ELIMINAR PRESENTACIÓN' + sLineBreak + sLineBreak +
      'Código: ' + codigoPresentacion + sLineBreak +
      'Descripción: ' + descripcionPresentacion + sLineBreak +
      'Precio: ' + FormatFloat('#,##0.00', precioPresentacion) + sLineBreak + sLineBreak +
      '¿Está seguro que desea eliminar esta presentación?',
      mtConfirmation, [mbYes, mbNo], 0) = mrNo then
      Exit;

    sqEliminar := TDBISAMQuery.Create(Self);
    try
      sqEliminar.DatabaseName := SQBuscarPresentacion.DatabaseName;

      // FO_CODE ES NUMÉRICO - NO USAR QuotedStr()
      sqEliminar.SQL.Text := 'DELETE FROM SinvOferta WHERE FO_CODE = ' + codigoPresentacion;
      sqEliminar.ExecSQL;

      if sqEliminar.RowsAffected > 0 then
      begin
        ShowMessage('Presentación eliminada exitosamente: ' + codigoPresentacion);
        ActualizarGridPresentaciones;
      end
      else
        ShowMessage('No se pudo eliminar la presentación.');
    finally
      sqEliminar.Free;
    end;
  except
    on E: Exception do
      ShowMessage('Error eliminando presentación: ' + E.Message);
  end;
end;

procedure TformArticulos.EliminarTodasLasPresentaciones;
var
  sqEliminar: TDBISAMQuery;
begin
  try
    if Trim(editCodigo.Text) = '' then
    begin
      ShowMessage('Debe seleccionar un producto primero.');
