procedure TformArticulos.ConfigurarQueryEtiquetas;
begin
  // Configurar query para presentaciones (ofertas)
  sqDetEtiquetasPresentaciones.Close;
  sqDetEtiquetasPresentaciones.SQL.Clear;
  sqDetEtiquetasPresentaciones.SQL.Add('SELECT FO_PRODUCTO, FO_DESCRIPCION, FO_UNDDESCARGA,');
  sqDetEtiquetasPresentaciones.SQL.Add('       (FO_MTOTOTAL / 100) AS FO_PRECIO_CALCULADO');
  sqDetEtiquetasPresentaciones.SQL.Add('FROM sinvoferta');
  sqDetEtiquetasPresentaciones.SQL.Add('WHERE FO_VISIBLE = TRUE AND FO_UNDDESCARGA <> 1');
  sqDetEtiquetasPresentaciones.SQL.Add('  AND FO_PRODUCTO = :CodigoProducto');
  sqDetEtiquetasPresentaciones.SQL.Add('ORDER BY FO_UNDDESCARGA');

  // Configurar query para inventario
  sqDetalleetiquetaInventario.Close;
  sqDetalleetiquetaInventario.SQL.Clear;
  sqDetalleetiquetaInventario.SQL.Add('SELECT I.FI_CODIGO, I.FI_DESCRIPCION, I.FI_CAPACIDAD,');
  sqDetalleetiquetaInventario.SQL.Add('       C.FIC_P01PRECIOTOTALEXT');
  sqDetalleetiquetaInventario.SQL.Add('FROM SINVENTARIO AS I');
  sqDetalleetiquetaInventario.SQL.Add('INNER JOIN a2InvCostosPrecios AS C ON I.FI_CODIGO = C.FIC_CODEITEM');
  sqDetalleetiquetaInventario.SQL.Add('WHERE I.FI_STATUS = TRUE AND I.FI_CAPACIDAD <> 1');
  sqDetalleetiquetaInventario.SQL.Add('  AND I.FI_CODIGO = :CodigoProducto');
  sqDetalleetiquetaInventario.SQL.Add('ORDER BY I.FI_CAPACIDAD');

  // Configurar datasets para FastReport
  fsqEtiqueta3.DataSet := sqDetEtiquetasPresentaciones;
  fsqEtiqueta3.UserName := 'dsPresentaciones';

  fsqDetalleEtiqueta2.DataSet := sqDetalleetiquetaInventario;
  fsqDetalleEtiqueta2.UserName := 'dsInventario';
end;

procedure TformArticulos.ProcesarEtiquetas(const CodigoProducto: string);
var
  TotalPresentaciones, TotalInventario: Integer;
  MensajeConfirmacion: string;
  Respuesta: Integer;
begin
  try
    // Configurar queries
    ConfigurarQueryEtiquetas;

    // Verificar datos disponibles
    sqDetEtiquetasPresentaciones.ParamByName('CodigoProducto').AsString := CodigoProducto;
    sqDetalleetiquetaInventario.ParamByName('CodigoProducto').AsString := CodigoProducto;

    sqDetEtiquetasPresentaciones.Open;
    sqDetalleetiquetaInventario.Open;

    TotalPresentaciones := sqDetEtiquetasPresentaciones.RecordCount;
    TotalInventario := sqDetalleetiquetaInventario.RecordCount;

    // Validar si hay datos
    if (TotalPresentaciones = 0) and (TotalInventario = 0) then
    begin
      ShowMessage('No se encontraron etiquetas para imprimir del código: ' + CodigoProducto);
      Exit;
    end;

    // Mostrar información y confirmar impresión
    MensajeConfirmacion := 'Código: ' + CodigoProducto + #13#10 +
                          'Presentaciones encontradas: ' + IntToStr(TotalPresentaciones) + #13#10 +
                          'Registros de inventario: ' + IntToStr(TotalInventario) + #13#10#13#10 +
                          '¿Desea imprimir las etiquetas?';

    Respuesta := Application.MessageBox(PChar(MensajeConfirmacion), 'Confirmar Impresión',
                                       MB_YESNO + MB_ICONQUESTION);

    if Respuesta = IDYES then
    begin
      // Imprimir según disponibilidad de datos
      if (TotalPresentaciones > 0) and (TotalInventario > 0) then
      begin
        // Ambos tipos de datos disponibles - preguntar qué imprimir
        Respuesta := Application.MessageBox(
          'Seleccione el tipo de etiquetas a imprimir:' + #13#10 +
          'SÍ = Solo Presentaciones' + #13#10 +
          'NO = Solo Inventario' + #13#10 +
          'CANCELAR = Ambos tipos',
          'Tipo de Etiquetas',
          MB_YESNOCANCEL + MB_ICONQUESTION);

        case Respuesta of
          IDYES: ImprimirEtiquetasPresentaciones(CodigoProducto);    // Presentaciones
          IDNO: ImprimirEtiquetasInventario(CodigoProducto);         // Inventario
          IDCANCEL: ImprimirEtiquetasProducto(CodigoProducto);       // Ambos
        end;
      end
      else if TotalPresentaciones > 0 then
        ImprimirEtiquetasPresentaciones(CodigoProducto)
      else
        ImprimirEtiquetasInventario(CodigoProducto);
    end;

  except
    on E: Exception do
    begin
      ShowMessage('Error al procesar etiquetas: ' + E.Message);
    end;
  end;

  // Cerrar queries al final
  if sqDetEtiquetasPresentaciones.Active then
    sqDetEtiquetasPresentaciones.Close;
  if sqDetalleetiquetaInventario.Active then
    sqDetalleetiquetaInventario.Close;
end;

