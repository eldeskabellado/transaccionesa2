procedure TformArticulos.editCapacidadExit(Sender: TObject);
begin
  CapacidadSeleccionado := StrToFloatDef(editCapacidad.Text, 1);
end;

procedure TformArticulos.editCostoExit(Sender: TObject);
var
  valor: string;
begin
  valor := StringReplace(editCosto.Text, FormatSettings.ThousandSeparator, '', [rfReplaceAll]);
  miCostoBs := StrToFloatDef(valor, 0);
  miCostoSeleccionado := miCostoBs / miFactor;

  if miUtilidad = 0 then
    miPrecioSeleccionado := miCostoBs
  else
    miPrecioSeleccionado := miCostoBs * (1 + (miUtilidad / 100));

  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.editDivisasExit(Sender: TObject);
var
  costoDivisas: Currency;
  valor: string;
begin
  valor := StringReplace(editDivisas.Text, FormatSettings.ThousandSeparator, '', [rfReplaceAll]);
  costoDivisas := StrToFloatDef(valor, 0);
  miCostoSeleccionado := costoDivisas;
  miCostoBs := miCostoSeleccionado * miFactor;

  if miUtilidad = 0 then
    miPrecioSeleccionado := miCostoBs
  else
    miPrecioSeleccionado := miCostoBs * (1 + (miUtilidad / 100));

  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;
  FormatearEdits;
end;

procedure TformArticulos.editPrecioExit(Sender: TObject);
var
  valor: string;
begin
  valor := StringReplace(editPrecio.Text, FormatSettings.ThousandSeparator, '', [rfReplaceAll]);
  miPrecioSeleccionado := StrToFloatDef(valor, 0);
  miPrecioDivisasSeleccionado := miPrecioSeleccionado / miFactor;

  if miCostoBs > 0 then
    miUtilidad := ((miPrecioSeleccionado - miCostoBs) / miCostoBs) * 100
  else
    miUtilidad := 0;

  FormatearEdits;
end;

procedure TformArticulos.editUtilidadExit(Sender: TObject);
var
  valor: string;
begin
  valor := editUtilidad.Text;
  valor := StringReplace(valor, '%', '', [rfReplaceAll]);
  valor := StringReplace(valor, FormatSettings.ThousandSeparator, '', [rfReplaceAll]);
  valor := Trim(valor);

  if valor = '' then
    miUtilidad := 0
  else
    miUtilidad := StrToFloatDef(valor, 0);

  CalcularUtilidadSolamente;
end;

procedure TformArticulos.editIVAExit(Sender: TObject);
var
  valor: string;
begin
  valor := StringReplace(editIVA.Text, ',', '', [rfReplaceAll]);
  miIVASeleccionado := StrToFloatDef(valor, 0);
end;

