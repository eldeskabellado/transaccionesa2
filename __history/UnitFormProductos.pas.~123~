procedure TformArticulos.btn2Click(Sender: TObject);
var
  formBuscar: TformBuscarArticulo;
begin
  btn1.Enabled := False;
  editIVA.Text := FloatToStr(miIVASeleccionado);
  LimpiarArrayCodigos;

  formBuscar := TformBuscarArticulo.Create(Self);
  try
    if formBuscar.ShowModal = mrOk then
    begin
      accion := 2;
      HabilitarControles(accion);
      editCodigo.Text := formBuscar.CodigoSeleccionado;
      editNombre.Text := formBuscar.NombreSeleccionado;
      editDivisas.Text := FloatToStr(formBuscar.DivisasSeleccionado);
      editUtilidad.Text := FloatToStr(formBuscar.UtilidadSeleccionado);
      editDetalle.Text := formBuscar.DetalleSeleccionado;

      // Actualizar grid de presentaciones
      ActualizarGridPresentaciones;

      // Llenar variables
      miCostoSeleccionado := formBuscar.CostoSeleccionado;
      miCostoBs := miCostoSeleccionado * miFactor;
      miPrecioDivisasSeleccionado := formBuscar.PrecioDivisasSeleccionado;
      miPrecioBs := miPrecioDivisasSeleccionado * miFactor;
      miUtilidad := formBuscar.UtilidadSeleccionado;
      CapacidadSeleccionado := formBuscar.CapacidadSeleccionado;

      editIVA.Text := FloatToStr(miIVASeleccionado);
      editDivisas.Text := FloatToStr(miCostoSeleccionado);
      editCosto.Text := FloatToStr(miCostoBs);
      editPrecio.Text := FloatToStr(miPrecioBs);
      editPrecioDivisas.Text := FloatToStr(miPrecioDivisasSeleccionado);
      editUtilidad.Text := FloatToStr(miUtilidad);
      editCapacidad.Text := FloatToStr(CapacidadSeleccionado);
      edtCATEGORIA.Text := formBuscar.obsertvaciones;
      cmb1.Text := 'PLASTICO';

      editCodigo.Enabled := False;
      if Assigned(edtCodAsociado) then edtCodAsociado.Clear;
      RefrescarGridCodigosAsociados;
      Self.Caption := 'Artículos - MODIFICAR';
      btnEtiqueta.Visible:=True;
    end;
  finally
    formBuscar.Free;
  end;
end;

