// ================================
// EVENTOS DE BOTONES CON MODO rgImpresion
// ================================

procedure TformEtiquetas.btn1Click(Sender: TObject);
begin
  try
    // Obtener tasa actualizada
    TasaMoneda := ObtenerTasaMoneda;

    case rgImpresion.ItemIndex of
      0: begin
        // Modo: Imprimir TODAS (con control de archivo)
        if Assigned(Label1) then
        begin
          Label1.Caption := 'Iniciando impresión de TODAS las ofertas...';
          Label1.Font.Color := clBlue;
          Application.ProcessMessages;
        end;
        ImprimirOfertasCompletas;
      end;

      1: begin
        // Modo: Imprimir POR CÓDIGO (sin control de archivo)
        if Trim(edtCodigo.Text) = '' then
        begin
          ShowMessage('Debe especificar un código de producto');
          edtCodigo.SetFocus;
          Exit;
        end;

        if Assigned(Label1) then
        begin
          Label1.Caption := 'Iniciando impresión por código...';
          Label1.Font.Color := clBlue;
          Application.ProcessMessages;
        end;
        ImprimirOfertaPorCodigo(Trim(edtCodigo.Text));
      end;
    else
      ShowMessage('Seleccione un modo de impresión');
    end;

  except
    on E: Exception do
    begin
      if Assigned(Label1) then
      begin
        Label1.Caption := 'Error en impresión de ofertas';
        Label1.Font.Color := clRed;
      end;
      ShowMessage('Error durante la impresión de ofertas: ' + E.Message);
    end;
  end;
end;

procedure TformEtiquetas.btnImpTodosClick(Sender: TObject);
begin
  try
    // Obtener tasa actualizada
    TasaMoneda := ObtenerTasaMoneda;

    case rgImpresion.ItemIndex of
      0: begin
        // Modo: Imprimir TODO (con control de archivo)
        if Assigned(Label1) then
        begin
          Label1.Caption := 'Iniciando impresión completa...';
          Label1.Font.Color := clBlue;
          Application.ProcessMessages;
        end;

        // Primero ofertas
        ShowMessage('Iniciando impresión de OFERTAS + presentaciones...');
        ImprimirOfertasCompletas;

        // Luego inventario
        ShowMessage('Iniciando impresión de INVENTARIO + presentaciones...');
        ImprimirInventarioCompleto;
      end;

      1: begin
        // Modo: Imprimir TODO por código específico (sin control de archivo)
        if Trim(edtCodigo.Text) = '' then
        begin
          ShowMessage('Debe especificar un código de producto');
          edtCodigo.SetFocus;
          Exit;
        end;

        if Assigned(Label1) then
        begin
          Label1.Caption := 'Iniciando impresión completa por código...';
          Label1.Font.Color := clBlue;
          Application.ProcessMessages;
        end;

        // Buscar e imprimir en ofertas
        ShowMessage('Buscando en OFERTAS...');
        ImprimirOfertaPorCodigo(Trim(edtCodigo.Text));

        // Buscar e imprimir en inventario
        ShowMessage('Buscando en INVENTARIO...');
        ImprimirInventarioPorCodigo(Trim(edtCodigo.Text));
      end;
    else
      ShowMessage('Seleccione un modo de impresión');
    end;

  except
    on E: Exception do
    begin
      if Assigned(Label1) then
      begin
        Label1.Caption := 'Error en impresión completa';
        Label1.Font.Color := clRed;
      end;
      ShowMessage('Error durante la impresión completa: ' + E.Message);
    end;
  end;
end;

procedure TformEtiquetas.btn2Click(Sender: TObject);
begin
  formbuscarProducto := TformbuscarProducto.Create(Application);
  try
    with formbuscarProducto do
    begin
      Caption := 'SELECCIONAR PRODUCTO (REFERENCIA)';
      ShowModal;
    end;
  finally
    edtCodigo.Text := formbuscarProducto.codigoproducto;
    formbuscarProducto.Free;
  end;
end;

end.
