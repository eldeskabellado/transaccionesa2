    pnl2: TPanel;
    lbl1: TLabel;
    edtCodigo: TEdit;
    pnl21: TPanel;
    btn1: TButton;
    btn2: TButton;
    lbl2: TLabel;
    rg1: TRadioGroup;
    fsqEtiqueta: TfrxDBDataset;
    frEtiqueta2: TfrxReport;
    sqBuscarPresentacion: TDBISAMQuery;
    btnImpTodos: TButton;
    Label1: TLabel;
    sqTasa: TDBISAMQuery;
    sqBuscarPresentacion2: TDBISAMQuery;
    fsqPresentacion: TfrxDBDataset;
    fsqFACTOR: TfrxDBDataset;
    repEtiqueta3: TfrxReport;
    fsqEtiqueta3: TfrxDBDataset;
    sqBuscarInventario: TDBISAMQuery;
    sqDetalleEtiqueta: TDBISAMQuery;  // Para presentaciones de OFERTAS
