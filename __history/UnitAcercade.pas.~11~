unit UnitAcercade;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants,
  System.Classes, Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs,
  Vcl.StdCtrls, Vcl.ExtCtrls, System.JSON, System.NetEncoding;

type
  TEvolutionResult = record
    Success: Boolean;
    StatusCode: Integer;
    Data: PAnsiChar;
    ErrorMessage: PAnsiChar;
  end;

  TformConectar = class(TForm)
    btnMostrarQR: TButton;
    imgQR: TImage;
    lblEstado: TLabel;
    Timer1: TTimer;
    procedure btnMostrarQRClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure Timer1Timer(Sender: TObject);
  private
    FConectado: Boolean;
    procedure ActualizarEstado;
  public
    { Public declarations }
  end;

var
  formConectar: TformConectar;

// ✅ SOLO las funciones que EXISTEN en tu DLL
function EVO_Initialize(const BaseURL, ApiKey, InstanceName: PAnsiChar): Boolean; stdcall; external 'evolution_api.dll';
procedure EVO_Cleanup; stdcall; external 'evolution_api.dll';
function EVO_GetQRCode(out Result: TEvolutionResult): Boolean; stdcall; external 'evolution_api.dll';
function EVO_GetConnectionState(out Result: TEvolutionResult): Boolean; stdcall; external 'evolution_api.dll';
function EVO_SendTextMessage(const PhoneNumber, Message: PAnsiChar; out Result: TEvolutionResult): Boolean; stdcall; external 'evolution_api.dll';

implementation

{$R *.dfm}

procedure TformConectar.FormCreate(Sender: TObject);
begin
  FConectado := False;
  imgQR.Visible := False;

  if EVO_Initialize(
    PAnsiChar(AnsiString('http://localhost:8080')),
    PAnsiChar(AnsiString('TU_API_KEY')),
    PAnsiChar(AnsiString('MI_INSTANCIA'))
  ) then
  begin
    lblEstado.Caption := 'DLL inicializada correctamente';
    lblEstado.Font.Color := clGreen;
    Timer1.Enabled := True;
  end
  else
  begin
    lblEstado.Caption := 'Error al inicializar DLL';
    lblEstado.Font.Color := clRed;
  end;
end;

procedure TformConectar.FormDestroy(Sender: TObject);
begin
  Timer1.Enabled := False;
  EVO_Cleanup;
end;

procedure TformConectar.Timer1Timer(Sender: TObject);
begin
  ActualizarEstado;
end;

procedure TformConectar.ActualizarEstado;
var
  Res: TEvolutionResult;
  JSON: TJSONObject;
  Estado: string;
begin
  if not EVO_GetConnectionState(Res) then Exit;

  JSON := TJSONObject.ParseJSONValue(string(Res.Data)) as TJSONObject;
  if Assigned(JSON) then
  try
    Estado := JSON.GetValue<string>('state');

    if Estado = 'open' then
    begin
      lblEstado.Caption := '✓ Conectado';
      lblEstado.Font.Color := clGreen;
      imgQR.Visible := False;
      btnMostrarQR.Enabled := False;
      FConectado := True;
    end
    else if Estado = 'close' then
    begin
      lblEstado.Caption := 'Desconectado - Genera QR para conectar';
      lblEstado.Font.Color := clRed;
      btnMostrarQR.Enabled := True;
      FConectado := False;
    end
    else
    begin
      lblEstado.Caption := 'Estado: ' + Estado;
      lblEstado.Font.Color := clBlue;
    end;
  finally
    JSON.Free;
  end;
  // ❌ NO llamar EVO_FreeResult
end;

procedure TformConectar.btnMostrarQRClick(Sender: TObject);
var
  Res: TEvolutionResult;
  JSON: TJSONObject;
  Base64QR: string;
  Stream: TMemoryStream;
  Bytes: TBytes;
begin
  lblEstado.Caption := 'Generando código QR...';
  Application.ProcessMessages;

  if not EVO_GetQRCode(Res) then
  begin
    ShowMessage('Error al obtener QR: ' + string(Res.ErrorMessage));
    Exit;
  end;

  JSON := TJSONObject.ParseJSONValue(string(Res.Data)) as TJSONObject;
  if not Assigned(JSON) then Exit;

  try
    Base64QR := JSON.GetValue<string>('qrcode');

    if Pos('base64,', Base64QR) > 0 then
      Base64QR := Copy(Base64QR, Pos('base64,', Base64QR) + 7, Length(Base64QR));

    Bytes := TNetEncoding.Base64.DecodeStringToBytes(Base64QR);

    Stream := TMemoryStream.Create;
    try
      Stream.WriteBuffer(Bytes[0], Length(Bytes));
      Stream.Position := 0;
      imgQR.Picture.LoadFromStream(Stream);
      imgQR.Stretch := True;
      imgQR.Proportional := True;
      imgQR.Visible := True;
    finally
      Stream.Free;
    end;

    lblEstado.Caption := 'Escanea el QR con WhatsApp';
    lblEstado.Font.Color := clBlue;
    ShowMessage('Escanea el código QR con WhatsApp en tu celular');
  finally
    JSON.Free;
  end;
  // ❌ NO llamar EVO_FreeResult
end;

end.
